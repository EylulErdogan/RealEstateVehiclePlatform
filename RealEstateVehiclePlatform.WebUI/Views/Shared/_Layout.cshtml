                <div class="d-flex gap-1 overflow-auto py-1" style="white-space: nowrap; -webkit-overflow-scrolling: touch;">
                    <button type="button" class="btn btn-xs btn-outline-primary chat-suggest-btn rounded-pill">En ucuz ilanlar</button>
                    <button type="button" class="btn btn-xs btn-outline-primary chat-suggest-btn rounded-pill">İstanbul İlanları</button>
                    <button type="button" class="btn btn-xs btn-outline-primary chat-suggest-btn rounded-pill">Ev İlanları</button>
