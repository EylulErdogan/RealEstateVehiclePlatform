@model RealEstateVehiclePlatform.WebUI.ViewModels.Appointment.CreateAppointmentViewModel

@{
    ViewData["Title"] = "Randevu Oluştur";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="appointment-page">
    <div class="container">
        <div class="appointment-wrapper">

            <div class="appointment-information">
                <span class="page-label">Randevu Sistemi</span>

                <h1>İlan için randevu oluştur</h1>

                <p class="page-description">
                    İlan sahibiyle görüşmek için uygun tarih ve saati seç.
                    Randevu talebin onaylandığında durumunu kullanıcı
                    panelinden takip edebilirsin.
                </p>

                <div class="listing-summary">
                    <div class="listing-summary-icon">
                        <i class="bi bi-buildings"></i>
                    </div>

                    <div>
                        <span class="listing-number">
                            @ViewBag.ListingNo
                        </span>

                        <h4>@ViewBag.ListingTitle</h4>

                        <p>
                            <i class="bi bi-geo-alt"></i>
                            @ViewBag.ListingAddress
                        </p>

                        <strong>
                            @(((decimal)ViewBag.ListingPrice).ToString("N0")) ₺
                        </strong>
                    </div>
                </div>

                <div class="appointment-notice">
                    <i class="bi bi-info-circle"></i>

                    <div>
                        <strong>Bilgilendirme</strong>

                        <p>
                            Aynı ilan için aynı tarih ve saatte yalnızca
                            bir randevu oluşturulabilir.
                        </p>
                    </div>
                </div>
            </div>

            <div class="appointment-form-card">
                <div class="form-card-header">
                    <div class="form-card-icon">
                        <i class="bi bi-calendar-check"></i>
                    </div>

                    <div>
                        <h3>Randevu Bilgileri</h3>
                        <p>Tarih, saat ve görüşme notunu gir.</p>
                    </div>
                </div>

                <form asp-action="Create" method="post">
                    <input asp-for="ListingId" type="hidden" />

                    <div class="mb-4">
                        <label asp-for="AppointmentDate"
                               class="form-label">
                            Randevu Tarihi ve Saati
                        </label>
                        <input type="datetime-local"
                               name="AppointmentDate"
                               value="@Model.AppointmentDate.ToString("yyyy-MM-ddTHH:mm")"
                               min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")"
                               class="form-control form-control-lg"
                               required />
                    </div>

                    <div class="mb-4">
                        <label asp-for="Note"
                               class="form-label">
                            Görüşme Notu
                        </label>

                        <textarea asp-for="Note"
                                  class="form-control"
                                  rows="5"
                                  placeholder="İlan sahibine iletmek istediğiniz notu yazın."></textarea>
                    </div>

                    <button type="submit"
                            class="btn appointment-submit-button">
                        <i class="bi bi-calendar-plus"></i>
                        Randevu Talebi Oluştur
                    </button>

                    <a href="/Listing/Detail/@Model.ListingId"
                       class="back-button">
                        <i class="bi bi-arrow-left"></i>
                        İlana geri dön
                    </a>
                </form>
            </div>

        </div>
    </div>
</section>

<style>
    .appointment-page {
        padding: 75px 0 100px;
        background: radial-gradient(circle at 10% 20%, rgba(37, 99, 235, .12), transparent 30%), #f8fafc;
    }

    .appointment-wrapper {
        display: grid;
        grid-template-columns: 1fr 480px;
        gap: 55px;
        align-items: center;
    }

    .page-label {
        display: block;
        margin-bottom: 12px;
        color: #2563eb;
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 1.5px;
        text-transform: uppercase;
    }

    .appointment-information h1 {
        max-width: 650px;
        margin-bottom: 18px;
        color: #0f172a;
        font-size: clamp(38px, 5vw, 58px);
        font-weight: 850;
        letter-spacing: -1.7px;
        line-height: 1.12;
    }

    .page-description {
        max-width: 650px;
        margin-bottom: 35px;
        color: #64748b;
        font-size: 17px;
        line-height: 1.75;
    }

    .listing-summary {
        display: flex;
        align-items: center;
        gap: 20px;
        max-width: 620px;
        padding: 24px;
        border: 1px solid #dbe3ef;
        border-radius: 22px;
        background: #fff;
        box-shadow: 0 15px 40px rgba(15, 23, 42, .07);
    }

    .listing-summary-icon {
        width: 85px;
        height: 85px;
        flex: 0 0 auto;
        display: grid;
        place-items: center;
        border-radius: 21px;
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: #fff;
        font-size: 38px;
    }

    .listing-number {
        color: #2563eb;
        font-size: 12px;
        font-weight: 800;
    }

    .listing-summary h4 {
        margin: 5px 0;
        color: #0f172a;
        font-weight: 800;
    }

    .listing-summary p {
        margin-bottom: 7px;
        color: #64748b;
        font-size: 14px;
    }

    .listing-summary strong {
        color: #2563eb;
        font-size: 21px;
    }

    .appointment-notice {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        max-width: 620px;
        margin-top: 22px;
        padding: 18px 20px;
        border-radius: 17px;
        background: #eff6ff;
        color: #1e40af;
    }

        .appointment-notice > i {
            font-size: 24px;
        }

        .appointment-notice p {
            margin: 4px 0 0;
            color: #475569;
            font-size: 14px;
        }

    .appointment-form-card {
        padding: 35px;
        border: 1px solid #e2e8f0;
        border-radius: 28px;
        background: #fff;
        box-shadow: 0 25px 65px rgba(15, 23, 42, .12);
    }

    .form-card-header {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 30px;
    }

    .form-card-icon {
        width: 58px;
        height: 58px;
        display: grid;
        place-items: center;
        border-radius: 17px;
        background: #eff6ff;
        color: #2563eb;
        font-size: 27px;
    }

    .form-card-header h3 {
        margin-bottom: 4px;
        color: #0f172a;
        font-weight: 800;
    }

    .form-card-header p {
        margin: 0;
        color: #64748b;
        font-size: 14px;
    }

    .form-label {
        color: #334155;
        font-weight: 700;
    }

    .form-control {
        border-color: #dbe3ef;
        border-radius: 13px;
    }

        .form-control:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 .2rem rgba(37, 99, 235, .12);
        }

    .appointment-submit-button {
        width: 100%;
        min-height: 54px;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        border: 0;
        border-radius: 14px;
        background: #2563eb;
        color: #fff;
        font-weight: 800;
    }

        .appointment-submit-button:hover {
            background: #1d4ed8;
            color: #fff;
        }

    .back-button {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 7px;
        margin-top: 16px;
        color: #64748b;
        font-weight: 700;
        text-decoration: none;
    }

        .back-button:hover {
            color: #2563eb;
        }

    @@media (max-width: 991.98px) {
        .appointment-wrapper {
            grid-template-columns: 1fr;
        }

        .appointment-form-card {
            max-width: 650px;
        }
    }
</style>