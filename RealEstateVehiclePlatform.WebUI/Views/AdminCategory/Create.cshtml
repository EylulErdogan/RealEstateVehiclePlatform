@model RealEstateVehiclePlatform.WebUI.ViewModels.Category.CreateCategoryViewModel

@{
    ViewData["Title"] = "Yeni Kategori";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-card">

    <div class="mb-4">
        <h4 class="fw-bold">Yeni Kategori</h4>
        <small class="text-muted">
            Sisteme yeni kategori ekleyebilirsiniz.
        </small>
    </div>

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger">
            @ViewBag.ErrorMessage
        </div>
    }

    <form asp-action="Create" method="post">

        <div class="mb-4">

            <label class="form-label fw-semibold">
                Kategori Adı
            </label>

            <input asp-for="Name"
                   class="form-control form-control-lg" />

        </div>

        <div class="d-flex gap-2">

            <button class="btn btn-primary">

                <i class="bi bi-check-circle"></i>

                Kaydet

            </button>

            <a href="/AdminCategory"
               class="btn btn-light">

                Vazgeç

            </a>

        </div>

    </form>

</div>