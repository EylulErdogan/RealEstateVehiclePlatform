@model List<RealEstateVehiclePlatform.WebUI.ViewModels.Listing.ListingViewModel>

@{
    ViewData["Title"] = "İlanlar";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="listing-page-hero">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end flex-wrap gap-3">
            <div>
                <span class="page-label">İlanları Keşfet</span>
                <h1>Ev, arsa ve araç ilanları</h1>
                <p>Aradığın ilana daha hızlı ulaşmak için filtreleri kullan.</p>
            </div>

            <span class="listing-count">
                @Model.Count ilan bulundu
            </span>
        </div>
    </div>
</section>

<section class="listing-page-section">
    <div class="container">
        <div class="filter-card mb-4">
            <form method="get" action="/Listing">
                <div class="row g-3 align-items-end">
                    <div class="col-lg-4">
                        <label class="form-label">Arama</label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-search"></i>
                            </span>

                            <input type="text"
                                   name="search"
                                   value="@Context.Request.Query["search"]"
                                   class="form-control"
                                   placeholder="İlan başlığı veya adres" />
                        </div>
                    </div>

                    <div class="col-md-4 col-lg-2">
                        <label class="form-label">Kategori</label>
                        <select name="category" class="form-select">
                            <option value="">Tümü</option>

                            @if (Context.Request.Query["category"] == "Ev")
                            {
                                <option value="Ev" selected>Ev</option>
                            }
                            else
                            {
                                <option value="Ev">Ev</option>
                            }

                            @if (Context.Request.Query["category"] == "Arsa")
                            {
                                <option value="Arsa" selected>Arsa</option>
                            }
                            else
                            {
                                <option value="Arsa">Arsa</option>
                            }

                            @if (Context.Request.Query["category"] == "Araç")
                            {
                                <option value="Araç" selected>Araç</option>
                            }
                            else
                            {
                                <option value="Araç">Araç</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4 col-lg-2">
                        <label class="form-label">Minimum Fiyat</label>

                        <input type="number"
                               name="minPrice"
                               value="@Context.Request.Query["minPrice"]"
                               class="form-control"
                               placeholder="0" />
                    </div>

                    <div class="col-md-4 col-lg-2">
                        <label class="form-label">Maksimum Fiyat</label>

                        <input type="number"
                               name="maxPrice"
                               value="@Context.Request.Query["maxPrice"]"
                               class="form-control"
                               placeholder="5.000.000" />
                    </div>

                    <div class="col-lg-1">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-funnel"></i>
                        </button>
                    </div>

                    <div class="col-lg-1">
                        <a href="/Listing" class="btn btn-outline-secondary w-100">
                            <i class="bi bi-x-circle"></i>
                        </a>
                    </div>
                </div>
            </form>
        </div>

        @if (Model.Any())
        {
            <div class="row g-4">
                @foreach (var item in Model)
                {
                    <div class="col-md-6 col-xl-4">
                        <article class="listing-card">
                            <div class="listing-image">
                                @if (!string.IsNullOrWhiteSpace(item.MainImageUrl))
                                {
                                    <img src="@item.MainImageUrl"
                                         alt="@item.Title"
                                         class="listing-card-image" />
                                }
                                else
                                {
                                    <div class="listing-image-placeholder">
                                        <i class="bi bi-buildings"></i>
                                    </div>
                                }

                                <span class="listing-number">
                                    @item.ListingNo
                                </span>

                                @if (Context.Session.GetString("Token") != null)
                                {
                                    <button type="button"
                                            class="favorite-button @(item.IsFavorite ? "is-favorite" : "")"
                                            data-listing-id="@item.Id">

                                        <i class="bi @(item.IsFavorite ? "bi-heart-fill" : "bi-heart")"></i>
                                    </button>
                                }
                                else
                                {
                                    <a href="/Account/Login"
                                       class="favorite-button"
                                       title="Favoriye eklemek için giriş yap">
                                        <i class="bi bi-heart"></i>
                                    </a>
                                }
                            </div>

                            <div class="listing-content">
                                <div class="listing-card-top">
                                    <span class="status-badge">
                                        Güncel İlan
                                    </span>

                                    <span class="view-count">
                                        <i class="bi bi-eye"></i>
                                        @item.ViewCount
                                    </span>
                                </div>

                                <h3>
                                    @item.Title
                                </h3>

                                <p class="listing-address">
                                    <i class="bi bi-geo-alt"></i>
                                    @item.Address
                                </p>

                                <div class="listing-card-footer">
                                    <strong>
                                        @item.Price.ToString("N0") ₺
                                    </strong>

                                    <a href="/Listing/Detail/@item.Id"
                                       class="detail-link">
                                        Detay
                                        <i class="bi bi-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        </article>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-result">
                <i class="bi bi-search"></i>
                <h3>İlan bulunamadı</h3>
                <p>Arama veya filtre seçeneklerini değiştirerek tekrar deneyebilirsin.</p>

                <a href="/Listing" class="btn btn-primary">
                    Filtreleri Temizle
                </a>
            </div>
        }
    </div>
</section>

<style>
    .listing-page-hero {
        padding: 65px 0 45px;
        background: radial-gradient(circle at 15% 20%, rgba(37, 99, 235, .14), transparent 30%), linear-gradient(135deg, #eff6ff, #f8fafc);
    }

    .page-label {
        display: block;
        margin-bottom: 8px;
        color: #2563eb;
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 1.5px;
        text-transform: uppercase;
    }

    .listing-page-hero h1 {
        margin-bottom: 10px;
        color: #0f172a;
        font-size: clamp(34px, 5vw, 52px);
        font-weight: 850;
        letter-spacing: -1.5px;
    }

    .listing-page-hero p {
        margin: 0;
        color: #64748b;
        font-size: 17px;
    }

    .listing-count {
        padding: 9px 15px;
        border-radius: 999px;
        background: #fff;
        color: #2563eb;
        font-weight: 700;
        box-shadow: 0 10px 30px rgba(15, 23, 42, .08);
    }

    .listing-page-section {
        padding: 45px 0 90px;
    }

    .filter-card {
        padding: 22px;
        border: 1px solid #e2e8f0;
        border-radius: 22px;
        background: #fff;
        box-shadow: 0 15px 40px rgba(15, 23, 42, .06);
    }

        .filter-card .form-label {
            color: #334155;
            font-size: 14px;
            font-weight: 700;
        }

        .filter-card .form-control,
        .filter-card .form-select,
        .filter-card .input-group-text {
            min-height: 48px;
            border-color: #dbe3ef;
        }

        .filter-card .input-group-text {
            background: #f8fafc;
            color: #2563eb;
        }

    .listing-card {
        height: 100%;
        overflow: hidden;
        border: 1px solid #e2e8f0;
        border-radius: 23px;
        background: #fff;
        box-shadow: 0 12px 35px rgba(15, 23, 42, .06);
        transition: .25s ease;
    }

        .listing-card:hover {
            transform: translateY(-7px);
            box-shadow: 0 24px 55px rgba(15, 23, 42, .13);
        }

    .listing-image {
        position: relative;
        min-height: 235px;
    }

    .listing-image-placeholder {
        min-height: 235px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #2563eb, #1e3a8a);
        color: rgba(255,255,255,.65);
        font-size: 72px;
    }

    .listing-number {
        position: absolute;
        left: 16px;
        bottom: 16px;
        padding: 7px 11px;
        border-radius: 9px;
        background: rgba(15, 23, 42, .7);
        color: #fff;
        font-size: 12px;
        font-weight: 700;
    }

    .favorite-button {
        position: absolute;
        top: 15px;
        right: 15px;
        width: 44px;
        height: 44px;
        display: grid;
        place-items: center;
        border: none;
        border-radius: 50%;
        background: #ffffff;
        color: #ef4444;
        font-size: 19px;
        cursor: pointer;
        transition: .2s ease;
    }

        .favorite-button.is-favorite {
            background: #ef4444;
            color: #ffffff;
        }

        .favorite-button:hover {
            color: #dc2626;
            transform: scale(1.06);
        }

    .listing-content {
        padding: 23px;
    }

    .listing-card-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 15px;
        margin-bottom: 14px;
    }

    .status-badge {
        padding: 6px 10px;
        border-radius: 999px;
        background: #dcfce7;
        color: #15803d;
        font-size: 12px;
        font-weight: 700;
    }

    .view-count {
        color: #94a3b8;
        font-size: 13px;
    }

    .listing-content h3 {
        min-height: 58px;
        margin-bottom: 10px;
        color: #0f172a;
        font-size: 20px;
        font-weight: 800;
        line-height: 1.45;
    }

    .listing-address {
        min-height: 44px;
        margin-bottom: 20px;
        color: #64748b;
        font-size: 14px;
    }

    .listing-card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 15px;
        padding-top: 18px;
        border-top: 1px solid #eef2f7;
    }

        .listing-card-footer strong {
            color: #2563eb;
            font-size: 21px;
        }

    .detail-link {
        color: #0f172a;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
    }

        .detail-link:hover {
            color: #2563eb;
        }

    .empty-result {
        padding: 75px 25px;
        border: 1px dashed #cbd5e1;
        border-radius: 25px;
        background: #fff;
        text-align: center;
    }

        .empty-result i {
            color: #94a3b8;
            font-size: 60px;
        }

        .empty-result h3 {
            margin-top: 20px;
            font-weight: 800;
        }

        .empty-result p {
            color: #64748b;
        }

    .listing-card-image {
        width: 100%;
        height: 235px;
        display: block;
        object-fit: cover;
    }
</style>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.querySelectorAll(".favorite-button").forEach((button) => {
        button.addEventListener("click", async function (event) {
        event.preventDefault();

        const listingId = this.dataset.listingId;

        const response = await fetch("/UserFavorite/Toggle", {
        method: "POST",
        headers: {
        "Content-Type": "application/x-www-form-urlencoded"
        },
        body: new URLSearchParams({
        listingId: listingId
        })
        });

        const result = await response.json();

        if (result.redirectUrl) {
        window.location.href = result.redirectUrl;
        return;
        }

        if (!result.success) {
        Swal.fire({
        icon: "error",
        title: "Hata",
        text: result.message
        });

        return;
        }

        const icon = this.querySelector("i");

        if (result.isFavorite === true) {
        this.classList.add("is-favorite");

        icon.classList.remove("bi-heart");
        icon.classList.add("bi-heart-fill");
        }
        else {
        this.classList.remove("is-favorite");

        icon.classList.remove("bi-heart-fill");
        icon.classList.add("bi-heart");
        }
        });
        });
    </script>
}