                </form>
            </div>
        </div>
    </div>

    <!-- CHATBOT TASARIM CSS -->
    <style>
        .ai-chatbot-widget {
        position: fixed;
        bottom: 30px;
        right: 30px;
        z-index: 9999;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        }

        .ai-chatbot-toggle-btn {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        position: relative;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        outline: none;
        }

        .ai-chatbot-toggle-btn:hover {
