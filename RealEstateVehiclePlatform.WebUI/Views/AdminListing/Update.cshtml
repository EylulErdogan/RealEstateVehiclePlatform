@model RealEstateVehiclePlatform.WebUI.ViewModels.Listing.CreateListingWizardViewModel

@{
    ViewData["Title"] = "Yeni İlan";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-card">
    <div class="mb-4">
        <h4 class="fw-bold">Yeni İlan Oluştur</h4>
        <small class="text-muted">Ev, arsa veya araç ilanını detaylarıyla ekleyebilirsin.</small>
    </div>

    <form asp-action="Create" method="post">

        <input asp-for="ListingNo" type="hidden" />

        <div class="row g-4">

            <div class="col-md-6">
                <label class="form-label fw-semibold">İlan Başlığı</label>
                <input asp-for="Title" class="form-control form-control-lg" />
            </div>

            <div class="col-md-6">
                <label class="form-label fw-semibold">Fiyat</label>
                <input asp-for="Price" class="form-control form-control-lg" />
            </div>

            <div class="col-md-4">
                <label class="form-label fw-semibold">Kategori</label>
                <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select form-select-lg" id="categorySelect">
                    <option value="">Kategori seçiniz</option>
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label fw-semibold">İlan Tipi</label>
                <select asp-for="ListingTypeId" asp-items="Model.ListingTypes" class="form-select form-select-lg">
                    <option value="">İlan tipi seçiniz</option>
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label fw-semibold">Şehir</label>
                <select asp-for="CityId" asp-items="Model.Cities" class="form-select form-select-lg">
                    <option value="">Şehir seçiniz</option>
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label fw-semibold">İlçe</label>
                <select asp-for="DistrictId" asp-items="Model.Districts" class="form-select form-select-lg">
                    <option value="">İlçe seçiniz</option>
                </select>
            </div>

            <div class="col-md-8">
                <label class="form-label fw-semibold">Adres</label>
                <input asp-for="Address" class="form-control form-control-lg" />
            </div>

            <div class="col-12">
                <label class="form-label fw-semibold">Açıklama</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            </div>
        </div>

        <hr class="my-4" />

        <div id="houseFields" class="detail-section d-none">
            <h5 class="fw-bold mb-3">Ev Detayları</h5>

            <div class="row g-4">
                <div class="col-md-3">
                    <label class="form-label">Oda Sayısı</label>
                    <input asp-for="RoomCount" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Salon Sayısı</label>
                    <input asp-for="LivingRoomCount" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Brüt m²</label>
                    <input asp-for="GrossSquareMeters" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Net m²</label>
                    <input asp-for="NetSquareMeters" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Bina Yaşı</label>
                    <input asp-for="BuildingAge" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Kat</label>
                    <input asp-for="FloorNumber" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Toplam Kat</label>
                    <input asp-for="TotalFloors" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Isıtma</label>
                    <input asp-for="HeatingType" class="form-control" />
                </div>

                <div class="col-md-3 form-check ms-3">
                    <input asp-for="HasBalcony" class="form-check-input" />
                    <label class="form-check-label">Balkon Var</label>
                </div>

                <div class="col-md-3 form-check">
                    <input asp-for="IsFurnished" class="form-check-input" />
                    <label class="form-check-label">Eşyalı</label>
                </div>
            </div>
        </div>

        <div id="landFields" class="detail-section d-none">
            <h5 class="fw-bold mb-3">Arsa Detayları</h5>

            <div class="row g-4">
                <div class="col-md-4">
                    <label class="form-label">Metrekare</label>
                    <input asp-for="SquareMeters" class="form-control" />
                </div>

                <div class="col-md-4">
                    <label class="form-label">İmar Durumu</label>
                    <input asp-for="ZoningStatus" class="form-control" />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Ada No</label>
                    <input asp-for="BlockNo" class="form-control" />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Parsel No</label>
                    <input asp-for="ParcelNo" class="form-control" />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Pafta No</label>
                    <input asp-for="SheetNo" class="form-control" />
                </div>

                <div class="col-md-4 form-check mt-5">
                    <input asp-for="IsSuitableForCredit" class="form-check-input" />
                    <label class="form-check-label">Krediye Uygun</label>
                </div>
            </div>
        </div>

        <div id="vehicleFields" class="detail-section d-none">
            <h5 class="fw-bold mb-3">Araç Detayları</h5>

            <div class="row g-4">
                <div class="col-md-3">
                    <label class="form-label">Marka</label>
                    <input asp-for="Brand" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Model</label>
                    <input asp-for="Model" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Yıl</label>
                    <input asp-for="Year" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Kilometre</label>
                    <input asp-for="Kilometer" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Yakıt Tipi</label>
                    <input asp-for="FuelType" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Vites Tipi</label>
                    <input asp-for="GearType" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Kasa Tipi</label>
                    <input asp-for="BodyType" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Renk</label>
                    <input asp-for="Color" class="form-control" />
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button class="btn btn-primary">
                <i class="bi bi-check-circle"></i>
                İlanı Kaydet
            </button>

            <a href="/AdminListing" class="btn btn-light">
                Vazgeç
            </a>
        </div>

    </form>
</div>

@section Scripts {
    <script>
        const categorySelect = document.getElementById("categorySelect");

        const houseFields = document.getElementById("houseFields");
        const landFields = document.getElementById("landFields");
        const vehicleFields = document.getElementById("vehicleFields");

        function hideAllDetails() {
            houseFields.classList.add("d-none");
            landFields.classList.add("d-none");
            vehicleFields.classList.add("d-none");
        }

        function showDetailFields() {
            hideAllDetails();

            const selectedText = categorySelect.options[categorySelect.selectedIndex].text.toLowerCase();

            if (selectedText.includes("ev")) {
                houseFields.classList.remove("d-none");
            }
            else if (selectedText.includes("arsa")) {
                landFields.classList.remove("d-none");
            }
            else if (selectedText.includes("araç") || selectedText.includes("arac")) {
                vehicleFields.classList.remove("d-none");
            }
        }

        categorySelect.addEventListener("change", showDetailFields);

        showDetailFields();
    </script>
}