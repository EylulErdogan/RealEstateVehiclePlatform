@model RealEstateVehiclePlatform.WebUI.ViewModels.Dashboard.AdminDashboardSummaryViewModel

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="admin-card dashboard-hero">
            <div>
                <span class="hero-badge">RealEstateVehiclePlatform</span>
                <h2>Admin Paneline Hoş Geldin 👋</h2>
                <p>İlanları, kullanıcıları, randevuları ve platform hareketlerini buradan yönetebilirsin.</p>
            </div>
            <i class="bi bi-buildings hero-icon"></i>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="admin-card h-100">
            <small class="text-muted">Bugünkü Özet</small>
            <h3 class="fw-bold mt-2 mb-3">@Model.PendingAppointmentCount Bekleyen İşlem</h3>

            <div class="progress mb-3" style="height:10px;">
                <div class="progress-bar" style="width:70%"></div>
            </div>

            <small class="text-muted">Sistem aktiviteleri admin onayı bekleyen işlemler üzerinden takip edilir.</small>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="admin-card stat-card">
            <div class="d-flex justify-content-between">
                <div>
                    <small class="text-muted">Toplam İlan</small>
                    <h3 class="fw-bold mt-2 mb-0">@Model.TotalListingCount</h3>
                    <small class="text-primary">Platformdaki tüm ilanlar</small>
                </div>
                <div class="stat-icon bg-primary-subtle text-primary">
                    <i class="bi bi-house-door"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="admin-card stat-card">
            <div class="d-flex justify-content-between">
                <div>
                    <small class="text-muted">Aktif İlan</small>
                    <h3 class="fw-bold mt-2 mb-0">@Model.ActiveListingCount</h3>
                    <small class="text-success">Yayındaki ilanlar</small>
                </div>
                <div class="stat-icon bg-success-subtle text-success">
                    <i class="bi bi-broadcast"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="admin-card stat-card">
            <div class="d-flex justify-content-between">
                <div>
                    <small class="text-muted">Kullanıcı</small>
                    <h3 class="fw-bold mt-2 mb-0">@Model.UserCount</h3>
                    <small class="text-warning">Kayıtlı kullanıcı</small>
                </div>
                <div class="stat-icon bg-warning-subtle text-warning">
                    <i class="bi bi-people"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="admin-card stat-card">
            <div class="d-flex justify-content-between">
                <div>
                    <small class="text-muted">Randevu</small>
                    <h3 class="fw-bold mt-2 mb-0">@Model.AppointmentCount</h3>
                    <small class="text-danger">@Model.PendingAppointmentCount bekliyor</small>
                </div>
                <div class="stat-icon bg-danger-subtle text-danger">
                    <i class="bi bi-calendar-check"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="admin-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h5 class="fw-bold mb-1">Platform Özeti</h5>
                    <small class="text-muted">Temel sistem verileri</small>
                </div>
                <span class="badge bg-primary-subtle text-primary">Canlı Veri</span>
            </div>

            <div class="summary-grid">
                <div>
                    <i class="bi bi-grid"></i>
                    <span>Kategori</span>
                    <strong>@Model.CategoryCount</strong>
                </div>

                <div>
                    <i class="bi bi-geo-alt"></i>
                    <span>Şehir</span>
                    <strong>@Model.CityCount</strong>
                </div>

                <div>
                    <i class="bi bi-hourglass-split"></i>
                    <span>Onay Bekleyen İlan</span>
                    <strong>@Model.PendingListingCount</strong>
                </div>

                <div>
                    <i class="bi bi-calendar-event"></i>
                    <span>Bekleyen Randevu</span>
                    <strong>@Model.PendingAppointmentCount</strong>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="admin-card">
            <h5 class="fw-bold mb-1">İlan Durumu</h5>
            <small class="text-muted">Aktif / bekleyen ilan oranı</small>

            <div class="status-ring my-4">
                <div class="ring-center">
                    <strong>@Model.TotalListingCount</strong>
                    <small>Toplam</small>
                </div>
            </div>

            <div class="d-flex justify-content-between">
                <span><i class="bi bi-circle-fill text-success"></i> Aktif İlan</span>
                <span class="fw-semibold">@Model.ActiveListingCount</span>
            </div>

            <div class="d-flex justify-content-between mt-2">
                <span><i class="bi bi-circle-fill text-warning"></i> Bekleyen İlan</span>
                <span class="fw-semibold">@Model.PendingListingCount</span>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="admin-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0">Yönetim Kısayolları</h5>
                <span class="text-muted small">Admin işlemleri</span>
            </div>

            <div class="quick-actions">
                <a href="/Category" class="quick-action">
                    <i class="bi bi-grid"></i>
                    <span>Kategoriler</span>
                </a>

                <a href="/Listing" class="quick-action">
                    <i class="bi bi-house-door"></i>
                    <span>İlanlar</span>
                </a>

                <a href="/AdminDashboard" class="quick-action">
                    <i class="bi bi-calendar-check"></i>
                    <span>Randevular</span>
                </a>

                <a href="/AdminDashboard" class="quick-action">
                    <i class="bi bi-people"></i>
                    <span>Kullanıcılar</span>
                </a>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="admin-card">
            <h5 class="fw-bold mb-3">Sistem Durumu</h5>

            <div class="timeline-item">
                <span></span>
                <div>
                    <strong>Dashboard verileri yüklendi</strong>
                    <p>Özet bilgiler EF API üzerinden başarıyla alındı.</p>
                    <small>Canlı veri</small>
                </div>
            </div>

            <div class="timeline-item">
                <span></span>
                <div>
                    <strong>JWT ve rol sistemi aktif</strong>
                    <p>Admin yetkileri ile korumalı endpoint yapısı hazır.</p>
                    <small>Güvenlik aktif</small>
                </div>
            </div>

            <div class="timeline-item">
                <span></span>
                <div>
                    <strong>WebUI API bağlantısı hazır</strong>
                    <p>MVC projesi HttpClient ile EF API üzerinden veri çekiyor.</p>
                    <small>Bağlantı başarılı</small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .dashboard-hero {
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: white;
        min-height: 210px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        overflow: hidden;
        position: relative;
    }

        .dashboard-hero h2 {
            font-weight: 800;
            margin-bottom: 12px;
        }

        .dashboard-hero p {
            opacity: .85;
            margin-bottom: 0;
            max-width: 560px;
        }

    .hero-badge {
        display: inline-block;
        background: rgba(255,255,255,.18);
        color: white;
        padding: 7px 14px;
        border-radius: 30px;
        font-size: 13px;
        margin-bottom: 18px;
    }

    .hero-icon {
        font-size: 110px;
        opacity: .18;
        position: absolute;
        right: 35px;
        bottom: 15px;
    }

    .stat-icon {
        width: 54px;
        height: 54px;
        border-radius: 16px;
        display: grid;
        place-items: center;
        font-size: 24px;
    }

    .stat-card {
        transition: .2s ease;
    }

        .stat-card:hover {
            transform: translateY(-4px);
        }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 18px;
    }

        .summary-grid div {
            background: #f8fafc;
            border-radius: 18px;
            padding: 22px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .summary-grid i {
            font-size: 28px;
            color: #2563eb;
        }

        .summary-grid span {
            color: #64748b;
            font-size: 14px;
        }

        .summary-grid strong {
            font-size: 26px;
            color: #0f172a;
        }

    .status-ring {
        width: 190px;
        height: 190px;
        margin-inline: auto;
        border-radius: 50%;
        background: conic-gradient(#22c55e 0 65%, #f59e0b 65% 100%);
        display: grid;
        place-items: center;
    }

    .ring-center {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: white;
        display: grid;
        place-items: center;
        text-align: center;
    }

        .ring-center strong {
            font-size: 30px;
            line-height: 1;
        }

        .ring-center small {
            color: #64748b;
            margin-top: -20px;
        }

    .quick-actions {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }

    .quick-action {
        background: #f8fafc;
        border-radius: 18px;
        padding: 22px;
        text-decoration: none;
        color: #0f172a;
        display: flex;
        align-items: center;
        gap: 14px;
        transition: .2s;
    }

        .quick-action:hover {
            background: #2563eb;
            color: white;
            transform: translateY(-3px);
        }

        .quick-action i {
            font-size: 28px;
        }

    .timeline-item {
        display: flex;
        gap: 14px;
        padding-bottom: 22px;
        position: relative;
    }

        .timeline-item > span {
            width: 12px;
            height: 12px;
            background: #2563eb;
            border-radius: 50%;
            margin-top: 6px;
            flex: 0 0 auto;
        }

        .timeline-item p {
            margin: 4px 0;
            color: #64748b;
        }

        .timeline-item small {
            color: #94a3b8;
        }
</style>