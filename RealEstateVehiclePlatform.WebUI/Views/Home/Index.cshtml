@model RealEstateVehiclePlatform.WebUI.ViewModels.Home.HomeViewModel

@{
    ViewData["Title"] = "Ana Sayfa";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Google Fonts: Plus Jakarta Sans Entegrasyonu -->
<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');

    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
    }
</style>

<!-- KAHRAMAN BÖLÜMÜ (HERO SECTION) -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-7 text-start">
                <span class="hero-badge animate-fade-in">
                    <i class="bi bi-stars me-2"></i>
                    Yeni Nesil İlan Platformu
                </span>

                <h1 class="hero-title animate-slide-up">
                    Aradığın Evi, Arsayı<br />
                    Veya Aracı <span>Kolayca Bul.</span>
                </h1>

                <p class="hero-description animate-slide-up-delay">
                    Güvenilir ilanları saniyeler içinde filtrele, favorilerine ekle, ilan sahipleriyle anlık mesajlaş ve randevu oluştur.
                </p>

                <!-- Modern Cam Efektli Arama Çubuğu -->
                <form action="/Listing" method="get" class="hero-search-bar animate-slide-up-delay-2 shadow">
                    <div class="search-input-group">
                        <div class="search-item">
                            <i class="bi bi-search text-primary"></i>
                            <input type="text" name="search" placeholder="Kelime veya ilan no ile ara..." autocomplete="off" />
                        </div>
                        <div class="search-item search-location border-start-lg">
                            <i class="bi bi-geo-alt-fill text-danger"></i>
                            <input type="text" name="city" placeholder="Şehir yazın..." autocomplete="off" />
                        </div>
                    </div>
                    <button type="submit" class="search-action-btn">
                        <i class="bi bi-funnel-fill me-1"></i> İlan Bul
                    </button>
                </form>

                <!-- Hızlı Sayaç İstatistikleri -->
                <div class="hero-stats-row animate-fade-in-delay">
                    <div class="stat-box">
                        <h3>@Model.LatestListings.Count+</h3>
                        <span>Aktif İlan</span>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat-box">
                        <h3>@Model.Categories.Count</h3>
                        <span>Ana Kategori</span>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat-box">
                        <h3>7/24</h3>
                        <span>Destek & Erişim</span>
                    </div>
                </div>
            </div>

            <!-- Sağ Taraf: Çok Katmanlı 3D Tasarımlı Görsel Alan -->
            <div class="col-lg-5 position-relative d-none d-lg-block">
                <div class="hero-visual-container">
                    <div class="hero-glow-back"></div>

                    <!-- Ana Cam Kart -->
                    <div class="hero-main-glass-card">
                        <div class="glass-icon-wrapper shadow">
                            <i class="bi bi-robot text-white"></i>
                        </div>
                        <h4>AI Destekli Arama</h4>
                        <p class="text-white-50 fs-8">Platformumuzdaki akıllı chatbot sayesinde aradığınız ilanı konuşarak bulabilirsiniz.</p>
                        <button type="button" onclick="document.getElementById('aiChatbotToggleBtn').click();" class="btn btn-sm btn-light rounded-pill px-3 py-2 fw-bold text-primary mt-2">Asistana Sor</button>
                    </div>

                    <!-- Uçan Kartlar (Floating Cards) -->
                    <div class="mini-floating-card top-card shadow-lg">
                        <div class="mini-card-icon bg-success-subtle text-success">
                            <i class="bi bi-shield-fill-check"></i>
                        </div>
                        <div>
                            <strong>Güvenli İlanlar</strong>
                            <small>Onaylı ilan filtreleri</small>
                        </div>
                    </div>

                    <div class="mini-floating-card bottom-card shadow-lg">
                        <div class="mini-card-icon bg-warning-subtle text-warning">
                            <i class="bi bi-calendar-check-fill"></i>
                        </div>
                        <div>
                            <strong>Anında Randevu</strong>
                            <small>Hızlı buluşma talepleri</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- KATEGORİLER BÖLÜMÜ (CATEGORIES SECTION) -->
<section class="category-section py-5 bg-white">
    <div class="container py-4">
        <div class="section-header-row mb-5">
            <div>
                <span class="premium-badge">Kategoriler</span>
                <h2 class="fw-extrabold text-dark mt-2 m-0">Ne Aramıştınız?</h2>
                <p class="text-muted mt-2">İhtiyacınıza en uygun kategoriyi seçerek aramayı daraltın.</p>
            </div>
            <a href="/Listing" class="view-all-btn">
                Tüm İlanlar <i class="bi bi-arrow-right-short fs-5"></i>
            </a>
        </div>

        <div class="row g-4">
            @foreach (var category in Model.Categories)
            {
                var (iconClass, themeClass) = category.Name.ToLower() switch
                {
                    "ev" => ("bi-house-door-fill", "category-theme-blue"),
                    "arsa" => ("bi-map-fill", "category-theme-green"),
                    "araç" => ("bi-car-front-fill", "category-theme-red"),
                    "arac" => ("bi-car-front-fill", "category-theme-red"),
                    _ => ("bi-grid-fill", "category-theme-purple")
                };

                <div class="col-md-4">
                    <a href="/Listing?category=@category.Name" class="category-premium-card @themeClass shadow-sm">
                        <div class="card-glow-bg"></div>
                        <div class="category-premium-icon shadow-sm">
                            <i class="bi @iconClass"></i>
                        </div>
                        <div class="category-card-info text-start">
                            <h4>@category.Name İlanları</h4>
                            <p>Güncel @category.Name.ToLower() ilanlarını listele.</p>
                        </div>
                        <span class="category-arrow-btn">
                            <i class="bi bi-arrow-up-right"></i>
                        </span>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

<!-- SON EKLENEN İLANLAR (LATEST LISTINGS SECTION) -->
<section class="latest-listings-section py-5 bg-light">
    <div class="container py-4">
        <div class="section-header-row mb-5">
            <div>
                <span class="premium-badge">Güncel Vitrin</span>
                <h2 class="fw-extrabold text-dark mt-2 m-0">Son Eklenen İlanlar</h2>
                <p class="text-muted mt-2">Platformumuza en son yüklenen güncel ilanları keşfedin.</p>
            </div>
            <a href="/Listing" class="view-all-btn">
                Tümünü İncele <i class="bi bi-arrow-right-short fs-5"></i>
            </a>
        </div>

        @if (Model.LatestListings.Any())
        {
            <div class="row g-4">
                @foreach (var listing in Model.LatestListings)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="listing-premium-card shadow-sm bg-white border border-light">
                            <!-- Görsel Alanı -->
                            <div class="listing-img-wrapper">
                                @if (!string.IsNullOrWhiteSpace(listing.MainImageUrl))
                                {
                                    <img src="@listing.MainImageUrl" alt="@listing.Title" class="listing-main-img" />
                                }
                                else
                                {
                                    <div class="listing-img-fallback">
                                        <i class="bi bi-image fs-1 text-white-50"></i>
                                    </div>
                                }
                                <span class="listing-no-tag shadow-sm">@listing.ListingNo</span>

                                <button type="button" class="listing-fav-btn shadow-sm" data-listing-id="@listing.Id" title="Favorilere Ekle">
                                    <i class="bi bi-heart"></i>
                                </button>
                            </div>

                            <!-- Bilgiler (Flexbox Düzen) -->
                            <div class="listing-body p-4 text-start">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="badge bg-success-subtle text-success rounded-pill px-3 py-1">Yeni İlan</span>
                                    <span class="text-muted fs-8"><i class="bi bi-eye-fill me-1"></i> @listing.ViewCount</span>
                                </div>

                                <!-- Sınırlandırılmış ve Yüksekliği Eşitlenmiş Başlık -->
                                <h5 class="listing-card-title fw-bold text-dark mb-2" title="@listing.Title">@listing.Title</h5>

                                <!-- Sınırlandırılmış ve Yüksekliği Eşitlenmiş Konum -->
                                <p class="listing-card-address text-secondary fs-8 mb-4">
                                    <i class="bi bi-geo-alt-fill text-primary me-1"></i> @listing.Address
                                </p>

                                <!-- En Alta Kilitlenen Footer -->
                                <div class="listing-card-footer d-flex justify-content-between align-items-center">
                                    <h4 class="m-0 fw-extrabold text-primary" style="font-size: 1.25rem;">@listing.Price.ToString("N0") ₺</h4>
                                    <a href="/Listing/Detail/@listing.Id" class="btn btn-sm btn-primary rounded-pill px-3 py-2 fw-bold d-flex align-items-center gap-1 shadow-sm">
                                        Detaylar <i class="bi bi-arrow-right-short fs-6"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-showcase-box text-center py-5 rounded-4 border border-dashed border-secondary border-opacity-25 bg-white">
                <i class="bi bi-house-exclamation fs-1 text-muted"></i>
                <h5 class="mt-3 fw-bold text-secondary">Henüz İlan Eklenmemiş</h5>
                <p class="text-muted fs-8">Sisteme yüklenen ilanlar anında burada listelenecektir.</p>
            </div>
        }
    </div>
</section>

<!-- PLATFORM ÖZELLİKLERİ (FEATURES SECTION) -->
<section class="features-section py-5 bg-white border-top">
    <div class="container py-3">
        <div class="features-premium-wrapper p-4 bg-light rounded-4 shadow-sm border border-light">
            <div class="row g-4 justify-content-center">
                <div class="col-sm-6 col-lg-3">
                    <div class="feature-p-item text-start">
                        <div class="feature-p-icon bg-primary-subtle text-primary shadow-sm"><i class="bi bi-shield-fill-check"></i></div>
                        <h6 class="fw-bold text-dark mt-3 mb-2">Güvenli Altyapı</h6>
                        <p class="text-secondary fs-8 m-0">Rol tabanlı güvenlik ve kontrollü ilan yönetim panelleri.</p>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="feature-p-item text-start">
                        <div class="feature-p-icon bg-danger-subtle text-danger shadow-sm"><i class="bi bi-heart-fill"></i></div>
                        <h6 class="fw-bold text-dark mt-3 mb-2">Favori Listesi</h6>
                        <p class="text-secondary fs-8 m-0">Beğendiğiniz ilanları listenize kaydedip dilediğiniz an inceleyin.</p>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="feature-p-item text-start">
                        <div class="feature-p-icon bg-success-subtle text-success shadow-sm"><i class="bi bi-calendar2-check-fill"></i></div>
                        <h6 class="fw-bold text-dark mt-3 mb-2">Akıllı Randevu</h6>
                        <p class="text-secondary fs-8 m-0">İlan sahipleriyle buluşma için anında randevu talebi gönderin.</p>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="feature-p-item text-start">
                        <div class="feature-p-icon bg-warning-subtle text-warning shadow-sm"><i class="bi bi-chat-dots-fill"></i></div>
                        <h6 class="fw-bold text-dark mt-3 mb-2">Hızlı İletişim</h6>
                        <p class="text-secondary fs-8 m-0">Dahili sohbet sistemi sayesinde doğrudan ilan sahibiyle yazışın.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ================= PREMIUM YENİ STYLESHEET ================= -->
<style>
    /* Kahraman Bölümü Tasarımı */
    .hero-section {
        position: relative;
        overflow: hidden;
        padding: 100px 0 120px;
        background: radial-gradient(circle at 12% 18%, rgba(37, 99, 235, 0.16), transparent 35%), radial-gradient(circle at 85% 75%, rgba(139, 92, 246, 0.12), transparent 30%), linear-gradient(135deg, #f8fafc 0%, #eff6ff 100%);
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        padding: 8px 16px;
        border-radius: 99px;
        background: rgba(37, 99, 235, 0.1);
        color: #2563eb;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.5px;
        margin-bottom: 25px;
        border: 1px solid rgba(37, 99, 235, 0.2);
    }

    .hero-title {
        color: #0f172a;
        font-size: clamp(38px, 4.5vw, 62px);
        font-weight: 850;
        line-height: 1.15;
        letter-spacing: -2px;
        margin-bottom: 20px;
    }

        .hero-title span {
            color: #2563eb;
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .hero-description {
        color: #64748b;
        font-size: 17px;
        line-height: 1.7;
        max-width: 600px;
        margin-bottom: 35px;
    }

    /* Cam Arama Çubuğu */
    .hero-search-bar {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 12px;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(226, 232, 240, 0.8);
        padding: 10px;
        border-radius: 20px;
        max-width: 680px;
        transition: all 0.3s ease;
    }

        .hero-search-bar:focus-within {
            border-color: #2563eb;
            box-shadow: 0 15px 40px rgba(37, 99, 235, 0.15) !important;
        }

    .search-input-group {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
    }

    .search-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0 12px;
    }

        .search-item i {
            font-size: 18px;
        }

        .search-item input {
            border: 0;
            outline: 0;
            background: transparent;
            font-size: 14px;
            color: #0f172a;
            width: 100%;
            font-weight: 500;
        }

    .search-action-btn {
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: white;
        border: 0;
        border-radius: 14px;
        font-weight: 700;
        padding: 12px 28px;
        font-size: 14px;
        transition: all 0.2s ease;
    }

        .search-action-btn:hover {
            background: linear-gradient(135deg, #1d4ed8, #1e40af);
            transform: translateY(-1px);
        }

    .hero-stats-row {
        display: flex;
        align-items: center;
        gap: 30px;
        margin-top: 45px;
    }

    .stat-box h3 {
        font-size: 26px;
        font-weight: 800;
        color: #0f172a;
        margin: 0 0 4px;
    }

    .stat-box span {
        color: #64748b;
        font-size: 13px;
        font-weight: 500;
    }

    .stat-divider {
        width: 1px;
        height: 35px;
        background: #cbd5e1;
    }

    /* 3D Görsel Alanı (Sağ) */
    .hero-visual-container {
        position: relative;
        height: 400px;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hero-glow-back {
        position: absolute;
        width: 250px;
        height: 250px;
        background: radial-gradient(circle, rgba(37,99,235,0.4) 0%, rgba(139,92,246,0) 70%);
        filter: blur(20px);
        z-index: 1;
        animation: rotate-glow 15s infinite linear;
    }

    @@keyframes rotate-glow {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    .hero-main-glass-card {
        background: linear-gradient(135deg, rgba(30, 41, 59, 0.95), rgba(15, 23, 42, 0.95));
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 30px;
        padding: 40px 30px;
        width: 78%;
        text-align: center;
        color: white;
        z-index: 2;
        box-shadow: 0 30px 60px rgba(15, 23, 42, 0.25);
        transform: perspective(1000px) rotateY(-5deg) rotateX(5deg);
        transition: all 0.5s ease;
    }

        .hero-main-glass-card:hover {
            transform: perspective(1000px) rotateY(0deg) rotateX(0deg);
        }

    .glass-icon-wrapper {
        width: 72px;
        height: 72px;
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 34px;
        margin: 0 auto 20px;
        background: linear-gradient(135deg, #2563eb, #8b5cf6);
    }

    .hero-main-glass-card h4 {
        font-weight: 800;
        font-size: 20px;
        margin-bottom: 10px;
    }

    .mini-floating-card {
        position: absolute;
        background: white;
        border-radius: 16px;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        z-index: 3;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

        .mini-floating-card:hover {
            transform: scale(1.08) translateY(-3px);
        }

    .mini-card-icon {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .mini-floating-card strong {
        display: block;
        font-size: 13px;
        color: #0f172a;
    }

    .mini-floating-card small {
        display: block;
        font-size: 11px;
        color: #64748b;
    }

    .top-card {
        top: 25px;
        right: -10px;
    }

    .bottom-card {
        bottom: 30px;
        left: -15px;
    }

    /* Başlık Gruplamaları */
    .section-header-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 20px;
    }

    .premium-badge {
        color: #2563eb;
        background: rgba(37,99,235,0.08);
        font-size: 12px;
        font-weight: 800;
        padding: 6px 12px;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: inline-block;
    }

    .view-all-btn {
        color: #2563eb;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 2px;
        font-size: 14px;
        transition: gap 0.2s ease;
    }

        .view-all-btn:hover {
            gap: 6px;
        }

    /* Premium Kategori Kartları */
    .category-premium-card {
        position: relative;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 22px;
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 16px;
        text-decoration: none;
        overflow: hidden;
        height: 100%;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .card-glow-bg {
        position: absolute;
        width: 150px;
        height: 150px;
        border-radius: 50%;
        filter: blur(40px);
        opacity: 0;
        z-index: 1;
        transition: opacity 0.3s ease;
    }

    .category-premium-icon {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
        position: relative;
        z-index: 2;
        flex-shrink: 0;
    }

    .category-card-info {
        position: relative;
        z-index: 2;
    }

        .category-card-info h4 {
            font-size: 16px;
            font-weight: 800;
            color: #0f172a;
            margin: 0 0 4px;
        }

        .category-card-info p {
            color: #64748b;
            font-size: 13px;
            margin: 0;
        }

    .category-arrow-btn {
        position: absolute;
        top: 20px;
        right: 20px;
        color: #94a3b8;
        font-size: 16px;
        z-index: 2;
        transition: all 0.3s ease;
    }

    /* Kategori Tema Renkleri */
    .category-theme-blue .category-premium-icon {
        background: #eff6ff;
        color: #2563eb;
    }

    .category-theme-blue .card-glow-bg {
        background: rgba(37,99,235,0.1);
        left: -40px;
        top: -40px;
    }

    .category-theme-blue:hover {
        border-color: #bfdbfe;
    }

    .category-theme-green .category-premium-icon {
        background: #f0fdf4;
        color: #10b981;
    }

    .category-theme-green .card-glow-bg {
        background: rgba(16,185,129,0.1);
        left: -40px;
        top: -40px;
    }

    .category-theme-green:hover {
        border-color: #bbf7d0;
    }

    .category-theme-red .category-premium-icon {
        background: #fef2f2;
        color: #ef4444;
    }

    .category-theme-red .card-glow-bg {
        background: rgba(239,68,68,0.1);
        left: -40px;
        top: -40px;
    }

    .category-theme-red:hover {
        border-color: #fecaca;
    }

    .category-premium-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 15px 30px rgba(15, 23, 42, 0.08) !important;
    }

        .category-premium-card:hover .card-glow-bg {
            opacity: 1;
        }

        .category-premium-card:hover .category-arrow-btn {
            color: #2563eb;
            transform: rotate(45deg);
        }

    /* FLAWLESS FLEXBOX SÜRÜSÜ İLE İLAN KARTLARI */
    .listing-premium-card {
        height: 100%;
        display: flex;
        flex-direction: column;
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.3s ease;
        background: #fff;
    }

        .listing-premium-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(15, 23, 42, 0.12) !important;
        }

    .listing-img-wrapper {
        position: relative;
        height: 220px;
        background: #1e293b;
        overflow: hidden;
        flex-shrink: 0;
    }

    .listing-main-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .listing-premium-card:hover .listing-main-img {
        transform: scale(1.08);
    }

    .listing-img-fallback {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #1e293b, #0f172a);
    }

