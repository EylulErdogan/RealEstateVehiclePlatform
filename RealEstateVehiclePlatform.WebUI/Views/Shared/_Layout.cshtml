<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - RealEstateVehiclePlatform</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
          rel="stylesheet" />

    <style>
            :root {
                --primary: #2563eb;
                --primary-dark: #1d4ed8;
                --dark: #0f172a;
                --muted: #64748b;
                --light: #f8fafc;
                --border: #e2e8f0;
            }

            body {
                margin: 0;
                background: var(--light);
                color: var(--dark);
                font-family: "Segoe UI", sans-serif;
            }

            .site-navbar {
                background: rgba(255, 255, 255, .96);
                border-bottom: 1px solid var(--border);
                box-shadow: 0 8px 30px rgba(15, 23, 42, .05);
                position: sticky;
                top: 0;
                z-index: 1000;
            }

            .navbar-brand-custom {
                color: var(--dark);
                font-size: 22px;
                font-weight: 800;
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 10px;
            }

                .navbar-brand-custom i {
                    color: var(--primary);
                    font-size: 28px;
                }

            .site-navbar .nav-link {
                color: #475569;
                font-weight: 600;
                border-radius: 10px;
                padding: 9px 13px !important;
                transition: .2s ease;
            }

                .site-navbar .nav-link:hover {
                    color: var(--primary);
                    background: #eff6ff;
                }

            .btn-listing {
                background: var(--primary);
                color: #fff;
                border: 0;
                border-radius: 12px;
                padding: 10px 18px;
                font-weight: 700;
                text-decoration: none;
            }

                .btn-listing:hover {
                    background: var(--primary-dark);
                    color: #fff;
                }

            .user-page-content {
                min-height: calc(100vh - 250px);
            }

            .site-footer {
                background: #0f172a;
                color: #cbd5e1;
                margin-top: 70px;
                padding: 55px 0 25px;
            }

                .site-footer h5 {
                    color: #fff;
                    font-weight: 700;
                    margin-bottom: 18px;
                }

                .site-footer a {
                    color: #cbd5e1;
                    text-decoration: none;
                }

                    .site-footer a:hover {
                        color: #fff;
                    }

            .footer-bottom {
                border-top: 1px solid rgba(255,255,255,.1);
                margin-top: 35px;
                padding-top: 22px;
                color: #94a3b8;
                font-size: 14px;
            }

            .profile-dropdown .dropdown-menu {
                border: 0;
                border-radius: 14px;
                box-shadow: 0 16px 40px rgba(15, 23, 42, .12);
                padding: 10px;
            }

            .profile-dropdown .dropdown-item {
                border-radius: 9px;
                padding: 10px 12px;
            }
    </style>
</head>

<body>

    <header class="site-navbar">
        <nav class="navbar navbar-expand-lg">
            <div class="container py-2">

                <a href="/" class="navbar-brand-custom">
                    <i class="bi bi-buildings"></i>
                    <span>RealEstate</span>
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#userNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="userNavbar">

                    <ul class="navbar-nav mx-auto gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link" href="/">
                                <i class="bi bi-house-door me-1"></i>
                                Ana Sayfa
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Listing">
                                <i class="bi bi-grid me-1"></i>
                                İlanlar
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Listing?category=Ev">
                                Ev
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Listing?category=Arsa">
                                Arsa
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Listing?category=Araç">
                                Araç
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-2">

                        @if (Context.Session.GetString("Token") != null)
                        {
                            <a href="/UserListing/Create" class="btn-listing">
                                <i class="bi bi-plus-circle me-1"></i>
                                İlan Ver
                            </a>

                            <div class="dropdown profile-dropdown">
                                <button class="btn btn-light dropdown-toggle"
                                        type="button"
                                        data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle me-1"></i>
                                    @Context.Session.GetString("FullName")
                                </button>

                                <ul class="dropdown-menu dropdown-menu-end">
                                    @if (Context.Session.GetString("Role") == "Admin")
                                    {
                                        <li>
                                            <a class="dropdown-item" href="/AdminDashboard">
                                                <i class="bi bi-speedometer2 me-2"></i>
                                                Admin Paneli
                                            </a>
                                        </li>
                                    }

                                    <li>
                                        <a class="dropdown-item" href="/UserProfile">
                                            <i class="bi bi-person me-2"></i>
                                            Profilim
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" href="/UserListing">
                                            <i class="bi bi-heart me-2"></i>
                                            İlanlarım
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="/UserFavorite">
                                            <i class="bi bi-heart me-2"></i>
                                            Favorilerim
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" href="/UserAppointment">
                                            <i class="bi bi-calendar-check me-2"></i>
                                            Randevularım
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" href="/UserMessage">
                                            <i class="bi bi-chat-dots me-2"></i>
                                            Mesajlarım
                                        </a>
                                    </li>

                                    <li><hr class="dropdown-divider" /></li>

                                    <li>
                                        <a class="dropdown-item text-danger" href="/Account/Logout">
                                            <i class="bi bi-box-arrow-right me-2"></i>
                                            Çıkış Yap
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a href="/Account/Login" class="btn btn-outline-primary">
                                Giriş Yap
                            </a>

                            <a href="/Account/Register" class="btn-listing">
                                Kayıt Ol
                            </a>
                        }

                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="user-page-content">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="row g-4">

                <div class="col-lg-4">
                    <h5>
                        <i class="bi bi-buildings me-2"></i>
                        RealEstateVehiclePlatform
                    </h5>

                    <p>
                        Ev, arsa ve araç ilanlarını güvenli ve kolay şekilde
                        keşfedebileceğiniz modern ilan platformu.
                    </p>
                </div>

                <div class="col-6 col-lg-2">
                    <h5>Platform</h5>
                    <div class="d-flex flex-column gap-2">
                        <a href="/">Ana Sayfa</a>
                        <a href="/Listing">İlanlar</a>
                        <a href="/Account/Login">Giriş Yap</a>
                        <a href="/Account/Register">Kayıt Ol</a>
                    </div>
                </div>

                <div class="col-6 col-lg-3">
                    <h5>Kategoriler</h5>
                    <div class="d-flex flex-column gap-2">
                        <a href="/Listing?category=Ev">Ev İlanları</a>
                        <a href="/Listing?category=Arsa">Arsa İlanları</a>
                        <a href="/Listing?category=Araç">Araç İlanları</a>
                    </div>
                </div>

                <div class="col-lg-3">
                    <h5>İletişim</h5>
                    <div class="d-flex flex-column gap-2">
                        <span>
                            <i class="bi bi-envelope me-2"></i>
                            info@realestate.com
                        </span>

                        <span>
                            <i class="bi bi-telephone me-2"></i>
                            +90 212 000 00 00
                        </span>
                    </div>
                </div>

            </div>

            <div class="footer-bottom d-flex justify-content-between flex-wrap gap-2">
                <span>
                    © @DateTime.Now.Year RealEstateVehiclePlatform
                </span>

                <span>
                    Tüm hakları saklıdır.
                </span>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>