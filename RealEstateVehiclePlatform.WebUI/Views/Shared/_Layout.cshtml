                    <input type="text" id="aiChatInput" class="form-control form-control-sm border-2 rounded-3" placeholder="Sorunuzu buraya yazın..." required autocomplete="off" style="font-size: 13px; height: 38px;" />
                    <button type="submit" class="btn btn-sm btn-primary d-flex align-items-center justify-content-center" style="width: 38px; height: 38px; border-radius: 8px;">
                        <i class="bi bi-send-fill text-white fs-6"></i>
