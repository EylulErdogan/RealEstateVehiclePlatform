@model List<string>

@{
    ViewData["Title"] = "Sistem Günlükleri";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-card">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
        <div>
            <h5 class="fw-bold mb-1"><i class="bi bi-journal-text text-primary me-2"></i>Sistem Günlükleri (Logs)</h5>
            <small class="text-muted">Platform genelindeki kullanıcı hareketleri ve sistem logları.</small>
        </div>

        @if (Model.Any())
        {
            <form asp-action="ClearLogs" method="post" onsubmit="return confirm('Tüm sistem loglarını silmek istediğinizden emin misiniz?');">
                <button type="submit" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-trash3 me-1"></i> Tüm Logları Temizle
                </button>
            </form>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm mb-4">
            <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
        </div>
    }

    @if (Model.Any())
    {
        <div class="log-console-wrapper rounded-3 p-3 bg-dark text-light overflow-auto" style="max-height: 580px; font-family: 'Courier New', Courier, monospace;">
            @foreach (var logLine in Model)
            {
                if (string.IsNullOrWhiteSpace(logLine)) continue;

                // Log satırına göre renk belirleme
                string colorClass = "text-light";
                if (logLine.Contains("[INFO]"))
                {
                    colorClass = "text-success-emphasis text-success";
                }
                else if (logLine.Contains("[WARNING]"))
                {
                    colorClass = "text-warning";
                }
                else if (logLine.Contains("[ERROR]"))
                {
                    colorClass = "text-danger";
                }

                <div class="log-line py-1 border-bottom border-secondary border-opacity-25 @colorClass" style="font-size: 13px;">
                    @logLine
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-journal-x fs-1 text-muted"></i>
            <h5 class="mt-3 text-secondary">Henüz bir log kaydı bulunmuyor</h5>
        </div>
    }
</div>