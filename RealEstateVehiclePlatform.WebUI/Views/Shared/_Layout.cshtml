<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - RealEstateVehiclePlatform</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
          rel="stylesheet" />

    <style>
            :root {
                --primary: #2563eb;
                --primary-dark: #1d4ed8;
                --dark: #0f172a;
                --muted: #64748b;
                --light: #f8fafc;
                --border: #e2e8f0;
            }

            body {
                margin: 0;
                background: var(--light);
                color: var(--dark);
                font-family: "Segoe UI", sans-serif;
            }

            .site-navbar {
                background: rgba(255, 255, 255, .96);
                border-bottom: 1px solid var(--border);
                box-shadow: 0 8px 30px rgba(15, 23, 42, .05);
                position: sticky;
                top: 0;
                z-index: 1000;
            }

            .navbar-brand-custom {
                color: var(--dark);
                font-size: 22px;
                font-weight: 800;
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 10px;
            }

                .navbar-brand-custom i {
                    color: var(--primary);
                    font-size: 28px;
                }

            .site-navbar .nav-link {
                color: #475569;
                font-weight: 600;
                border-radius: 10px;
                padding: 9px 13px !important;
                transition: .2s ease;
            }

                .site-navbar .nav-link:hover {
                    color: var(--primary);
                    background: #eff6ff;
                }

            .btn-listing {
                background: var(--primary);
                color: #fff;
                border: 0;
                border-radius: 12px;
                padding: 10px 18px;
                font-weight: 700;
                text-decoration: none;
            }

                .btn-listing:hover {
                    background: var(--primary-dark);
                    color: #fff;
                }

            .user-page-content {
                min-height: calc(100vh - 250px);
            }

            .site-footer {
                background: #0f172a;
                color: #cbd5e1;
                margin-top: 70px;
                padding: 55px 0 25px;
            }

                .site-footer h5 {
                    color: #fff;
                    font-weight: 700;
                    margin-bottom: 18px;
                }

                .site-footer a {
                    color: #cbd5e1;
                    text-decoration: none;
                }

                    .site-footer a:hover {
                        color: #fff;
                    }

            .footer-bottom {
                border-top: 1px solid rgba(255,255,255,.1);
                margin-top: 35px;
                padding-top: 22px;
                color: #94a3b8;
                font-size: 14px;
            }

            .profile-dropdown .dropdown-menu {
                border: 0;
                border-radius: 14px;
                box-shadow: 0 16px 40px rgba(15, 23, 42, .12);
                padding: 10px;
            }

            .profile-dropdown .dropdown-item {
                border-radius: 9px;
                padding: 10px 12px;
            }

            .fs-7 {
                font-size: 0.85rem;
            }

            .fs-8 {
                font-size: 0.75rem;
            }
    </style>
</head>

