        }

        .ai-chat-header {
        background: linear-gradient(135deg, #1e293b, #0f172a);
        color: white;
        padding: 12px 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        }

        .ai-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #2563eb;
        display: flex;
        align-items: center;
        justify-content: center;
