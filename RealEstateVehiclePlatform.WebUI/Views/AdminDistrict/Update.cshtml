@model RealEstateVehiclePlatform.WebUI.ViewModels.District.UpdateDistrictViewModel

@{
    ViewData["Title"] = "İlçe Güncelle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-card">
    <div class="mb-4">
        <h4 class="fw-bold">İlçe Güncelle</h4>
        <small class="text-muted">İlçe ve bağlı olduğu şehir bilgisini düzenleyebilirsiniz.</small>
    </div>

    <form asp-action="Update" method="post">
        <input asp-for="Id" type="hidden" />

        <div class="mb-4">
            <label class="form-label fw-semibold">İlçe Adı</label>
            <input asp-for="Name" class="form-control form-control-lg" />
        </div>

        <div class="mb-4">
            <label class="form-label fw-semibold">Şehir</label>
            <select asp-for="CityId" asp-items="Model.Cities" class="form-select form-select-lg">
                <option value="">Şehir seçiniz</option>
            </select>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-success">
                <i class="bi bi-arrow-repeat"></i>
                Güncelle
            </button>

            <a href="/AdminDistrict" class="btn btn-light">
                Vazgeç
            </a>
        </div>
    </form>
</div>