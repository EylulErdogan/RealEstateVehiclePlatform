    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- SweetAlert2 Global Kütüphane Entegrasyonu -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- BİLDİRİM AJAN DÖNGÜSÜ SCRIPT'I (Sadece Oturum Açıkken Çalışır) -->
    @if (Context.Session.GetString("Token") != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
            let lastUnreadCount = 0;

            async function checkNotifications() {
            try {
            const response = await fetch('/Notification/GetNotifications');
            const result = await response.json();

            if (result.success) {
            const badge = document.getElementById('notificationBadge');
            const headerBadge = document.getElementById('notificationHeaderBadge');
            const container = document.getElementById('notificationItemsContainer');

            // Sayaç Güncellemeleri
            if (result.unreadCount > 0) {
            badge.textContent = result.unreadCount;
            badge.classList.remove('d-none');
            headerBadge.textContent = `${result.unreadCount} Yeni`;
            } else {
            badge.classList.add('d-none');
            headerBadge.textContent = '0 Yeni';
            }

            // Eğer yeni okunmamış mesaj gelirse sağ üst köşede Toast fırlat
            if (result.unreadCount > lastUnreadCount && lastUnreadCount > 0) {
            Swal.fire({
            toast: true,
            position: 'top-end',
            icon: 'info',
            title: 'Yeni bir mesajınız var!',
            showConfirmButton: false,
            timer: 3000
            });
            }
            lastUnreadCount = result.unreadCount;

            // Arayüze bildirimleri yerleştirme
            if (result.data && result.data.length > 0) {
            container.innerHTML = '';
            result.data.forEach(item => {
            const li = document.createElement('li');
            li.className = 'p-2 border-bottom';
            li.style.listStyle = 'none';
            li.innerHTML = `
            <a href="${item.url}" class="d-flex align-items-start gap-2 text-decoration-none text-dark">
            <div class="rounded-circle bg-light d-grid place-items-center" style="width:36px; height:36px; flex-shrink:0; margin-top:2px;">
            <i class="bi ${item.icon} fs-5"></i>
            </div>
            <div class="flex-grow-1" style="min-width: 0;">
            <div class="d-flex justify-content-between align-items-center">
            <span class="fw-bold text-dark fs-7" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${item.title}</span>
            <small class="text-muted fs-8">${item.time}</small>
            </div>
            <p class="m-0 text-secondary fs-8 text-truncate">${item.message}</p>
            </div>
            </a>
            `;
            container.appendChild(li);
            });
            } else {
            container.innerHTML = `
            <div class="text-center py-4 text-muted">
            <i class="bi bi-bell-slash fs-3"></i>
            <p class="m-0 mt-2 fs-8">Yeni bildiriminiz bulunmuyor</p>
            </div>
            `;
            }
            }
            } catch (error) {
            console.error('Bildirimler yüklenirken hata oluştu:', error);
            }
            }

            // İlk yüklemede çalıştır
            checkNotifications();

            // Her 20 saniyede bir arka planda kontrol et (AJAX Polling)
            setInterval(checkNotifications, 20000);
            });
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
    <!-- ================= CHATBOT YAPAY ZEKA ASİSTANI WIDGET ================= -->
    <div id="aiChatbotWidget" class="ai-chatbot-widget">
