@model List<RealEstateVehiclePlatform.WebUI.ViewModels.Appointment.UserAppointmentViewModel>

@{
    ViewData["Title"] = "Randevularım";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="appointment-list-header">
    <div class="container">
        <span class="page-label">Kullanıcı Paneli</span>

        <div class="d-flex justify-content-between align-items-end flex-wrap gap-3">
            <div>
                <h1>Randevularım</h1>

                <p>
                    Oluşturduğun randevu taleplerini ve durumlarını
                    buradan takip edebilirsin.
                </p>
            </div>

            <span class="appointment-count">
                @Model.Count randevu
            </span>
        </div>
    </div>
</section>

<section class="appointment-list-content">
    <div class="container">

        @if (Model.Any())
        {
            <div class="appointment-list">
                @foreach (var item in Model.OrderByDescending(x => x.AppointmentDate))
                {
                    var statusText = item.Status switch
                    {
                        1 => "Bekliyor",
                       2 => "Onaylandı",
                        3 => "Reddedildi",
                       4 => "Tamamlandı",
                        5 => "İptal Edildi",
                        _ => "Bilinmiyor"
                    };

                    var statusClass = item.Status switch
                    {
                       1 => "status-pending",
                        2 => "status-approved",
                        3 => "status-rejected",
                        4 => "status-completed",
                        5 => "status-cancelled",
                        _ => "status-cancelled"
                    };

                    <article class="appointment-card">
                        <div class="appointment-date-box">
                            <strong>
                                @item.AppointmentDate.ToString("dd")
                            </strong>

                            <span>
                                @item.AppointmentDate.ToString("MMM")
                            </span>

                            <small>
                                @item.AppointmentDate.ToString("yyyy")
                            </small>
                        </div>

                        <div class="appointment-main">
                            <div class="appointment-card-top">
                                <div>
                                    <span class="appointment-number">
                                        Randevu #@item.Id
                                    </span>

                                    <h3>
                                        İlan #@item.ListingId için görüşme
                                    </h3>
                                </div>

                                <span class="appointment-status @statusClass">
                                    @statusText
                                </span>
                            </div>

                            <div class="appointment-details">
                                <span>
                                    <i class="bi bi-clock"></i>
                                    @item.AppointmentDate.ToString("HH:mm")
                                </span>

                                <span>
                                    <i class="bi bi-calendar3"></i>
                                    @item.AppointmentDate.ToString("dddd")
                                </span>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(item.Note))
                            {
                                <p class="appointment-note">
                                    <i class="bi bi-chat-left-text"></i>
                                    @item.Note
                                </p>
                            }

                            <div class="appointment-actions">
                                <a href="/Listing/Detail/@item.ListingId"
                                   class="detail-button">
                                    <i class="bi bi-eye"></i>
                                    İlanı Görüntüle
                                </a>

                                @if (item.Status == 0 || item.Status == 1)
                                {
                                    <form asp-action="Cancel"
                                          method="post"
                                          class="cancel-appointment-form">

                                        <input type="hidden"
                                               name="id"
                                               value="@item.Id" />

                                        <button type="submit"
                                                class="cancel-button">
                                            <i class="bi bi-x-circle"></i>
                                            Randevuyu İptal Et
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="empty-appointments">
                <div class="empty-icon">
                    <i class="bi bi-calendar2-x"></i>
                </div>

                <h3>Henüz randevun bulunmuyor</h3>

                <p>
                    İlgilendiğin ilanların detay sayfasından
                    randevu talebi oluşturabilirsin.
                </p>

                <a href="/Listing" class="btn btn-primary">
                    <i class="bi bi-search me-1"></i>
                    İlanları Keşfet
                </a>
            </div>
        }

    </div>
</section>

<style>
    .appointment-list-header {
        padding: 65px 0 45px;
        background: radial-gradient(circle at 15% 20%, rgba(37, 99, 235, .14), transparent 30%), linear-gradient(135deg, #eff6ff, #f8fafc);
    }

    .page-label {
        display: block;
        margin-bottom: 8px;
        color: #2563eb;
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 1.5px;
        text-transform: uppercase;
    }

    .appointment-list-header h1 {
        margin-bottom: 10px;
        color: #0f172a;
        font-size: clamp(34px, 5vw, 52px);
        font-weight: 850;
        letter-spacing: -1.5px;
    }

    .appointment-list-header p {
        margin: 0;
        color: #64748b;
        font-size: 17px;
    }

    .appointment-count {
        padding: 9px 15px;
        border-radius: 999px;
        background: #fff;
        color: #2563eb;
        font-weight: 700;
        box-shadow: 0 10px 30px rgba(15, 23, 42, .08);
    }

    .appointment-list-content {
        padding: 50px 0 90px;
    }

    .appointment-list {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .appointment-card {
        display: grid;
        grid-template-columns: 115px 1fr;
        gap: 25px;
        padding: 25px;
        border: 1px solid #e2e8f0;
        border-radius: 23px;
        background: #fff;
        box-shadow: 0 12px 35px rgba(15, 23, 42, .06);
    }

    .appointment-date-box {
        min-height: 125px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        border-radius: 19px;
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: #fff;
    }

        .appointment-date-box strong {
            font-size: 36px;
            line-height: 1;
        }

        .appointment-date-box span {
            margin-top: 5px;
            font-weight: 800;
            text-transform: uppercase;
        }

        .appointment-date-box small {
            color: rgba(255,255,255,.7);
        }

    .appointment-card-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 20px;
    }

    .appointment-number {
        color: #2563eb;
        font-size: 12px;
        font-weight: 800;
    }

    .appointment-card h3 {
        margin: 5px 0 0;
        color: #0f172a;
        font-size: 21px;
        font-weight: 800;
    }

    .appointment-status {
        padding: 7px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 800;
        white-space: nowrap;
    }

    .status-pending {
        background: #fef3c7;
        color: #b45309;
    }

    .status-approved {
        background: #dcfce7;
        color: #15803d;
    }

    .status-rejected {
        background: #fee2e2;
        color: #b91c1c;
    }

    .status-completed {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .status-cancelled {
        background: #e2e8f0;
        color: #475569;
    }

    .appointment-details {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        margin-top: 18px;
        color: #64748b;
        font-size: 14px;
    }

        .appointment-details span {
            display: flex;
            align-items: center;
            gap: 7px;
        }

    .appointment-note {
        margin: 18px 0 0;
        padding: 15px 17px;
        border-radius: 13px;
        background: #f8fafc;
        color: #475569;
    }

    .appointment-actions {
        display: flex;
        gap: 12px;
        margin-top: 20px;
        padding-top: 18px;
        border-top: 1px solid #eef2f7;
    }

    .detail-button,
    .cancel-button {
        min-height: 42px;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        border-radius: 11px;
        padding: 0 15px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
    }

    .detail-button {
        background: #eff6ff;
        color: #1d4ed8;
    }

    .cancel-button {
        border: 1px solid #fecaca;
        background: #fff;
        color: #dc2626;
    }

        .cancel-button:hover {
            background: #fef2f2;
        }

    .empty-appointments {
        max-width: 650px;
        margin: 0 auto;
        padding: 75px 30px;
        border: 1px dashed #cbd5e1;
        border-radius: 25px;
        background: #fff;
        text-align: center;
    }

    .empty-icon {
        width: 92px;
        height: 92px;
        margin: 0 auto;
        display: grid;
        place-items: center;
        border-radius: 50%;
        background: #eff6ff;
        color: #2563eb;
        font-size: 42px;
    }

    .empty-appointments h3 {
        margin-top: 22px;
        font-weight: 800;
    }

    .empty-appointments p {
        max-width: 480px;
        margin: 12px auto 25px;
        color: #64748b;
        line-height: 1.7;
    }

    @@media (max-width: 767.98px) {
        .appointment-card {
            grid-template-columns: 1fr;
        }

        .appointment-date-box {
            min-height: 105px;
        }

        .appointment-card-top {
            flex-direction: column;
        }

        .appointment-actions {
            align-items: stretch;
            flex-direction: column;
        }

        .detail-button,
        .cancel-button {
            justify-content: center;
            width: 100%;
        }
    }
</style>