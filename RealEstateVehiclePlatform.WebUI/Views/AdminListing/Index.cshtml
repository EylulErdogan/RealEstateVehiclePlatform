@model List<RealEstateVehiclePlatform.WebUI.ViewModels.Listing.ListingViewModel>

@{
    ViewData["Title"] = "İlan Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-card">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="fw-bold mb-1">İlan Yönetimi</h5>
            <small class="text-muted">
                Kullanıcıların eklediği ilanları detaylı inceleyebilir, onaylayabilir veya pasife alabilirsiniz.
            </small>
        </div>

        <span class="badge bg-primary-subtle text-primary fs-6">
            @Model.Count ilan
        </span>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm mb-3">
            <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm mb-3">
            <i class="bi bi-exclamation-triangle me-1"></i> @TempData["Error"]
        </div>
    }

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table align-middle table-hover">
                <thead>
                    <tr>
                        <th>İlan No</th>
                        <th>Başlık</th>
                        <th>Fiyat</th>
                        <th>Kullanıcı ID</th>
                        <th>Durum</th>
                        <th class="text-end" style="min-width:280px;">
                            İşlemler
                        </th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        var statusText = item.Status switch
                        {
                            1 => "Onay Bekliyor",
                            2 => "Aktif",
                            3 => "Pasif",
                            4 => "Reddedildi",
                            _ => "Bilinmiyor"
                        };

                        var statusClass = item.Status switch
                        {
                            1 => "bg-warning-subtle text-warning-emphasis",
                            2 => "bg-success-subtle text-success",
                            3 => "bg-secondary-subtle text-secondary",
                            4 => "bg-danger-subtle text-danger",
                            _ => "bg-light text-dark"
                        };

                        <tr>
                            <td>
                                <span class="badge bg-primary-subtle text-primary">
                                    @item.ListingNo
                                </span>
                            </td>

                            <td>
                                <strong>@item.Title</strong>
                                <small class="d-block text-muted">
                                    @item.Address
                                </small>
                            </td>

                            <td class="fw-semibold">
                                @item.Price.ToString("N0") ₺
                            </td>

                            <td>
                                #@item.UserId
                            </td>

                            <td>
                                <span class="badge @statusClass">
                                    @statusText
                                </span>
                            </td>

                            <td class="text-end">
                                <!-- Admin İlan İnceleme Detay Butonu (YENİ EKLENDİ) -->
                                <a href="/AdminListing/Detail/@item.Id"
                                   class="btn btn-sm btn-info text-white me-1"
                                   title="İlanı İncele (Yönetim)">
                                    <i class="bi bi-search"></i>
                                </a>

                                <a href="/Listing/Detail/@item.Id"
                                   target="_blank"
                                   class="btn btn-sm btn-outline-primary me-1"
                                   title="Müşteri Gözünden Önizle">
                                    <i class="bi bi-eye"></i>
                                </a>

                                @if (item.Status != 2)
                                {
                                    <form asp-action="Approve"
                                          method="post"
                                          class="d-inline">
                                        <input type="hidden"
                                               name="id"
                                               value="@item.Id" />
                                        <button type="submit"
                                                class="btn btn-sm btn-success me-1"
                                                title="Onayla">
                                            <i class="bi bi-check-circle"></i>
                                        </button>
                                    </form>
                                }

                                @if (item.Status == 1)
                                {
                                    <form asp-action="Reject"
                                          method="post"
                                          class="d-inline">
                                        <input type="hidden"
                                               name="id"
                                               value="@item.Id" />
                                        <button type="submit"
                                                class="btn btn-sm btn-danger me-1"
                                                title="Reddet">
                                            <i class="bi bi-x-circle"></i>
                                        </button>
                                    </form>
                                }

                                @if (item.Status == 2)
                                {
                                    <form asp-action="MakePassive"
                                          method="post"
                                          class="d-inline">
                                        <input type="hidden"
                                               name="id"
                                               value="@item.Id" />
                                        <button type="submit"
                                                class="btn btn-sm btn-warning text-dark me-1"
                                                title="Pasife Al">
                                            <i class="bi bi-pause-circle"></i>
                                        </button>
                                    </form>
                                }

                                <a href="#"
                                   class="btn btn-sm btn-soft-danger delete-btn"
                                   data-url="/AdminListing/Delete/@item.Id"
                                   data-title="@item.Title ilanı silinecek.">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-card-list fs-1 text-muted"></i>
            <h5 class="mt-3">Henüz ilan bulunmuyor</h5>
        </div>
    }

</div>