@model List<RealEstateVehiclePlatform.WebUI.ViewModels.Category.CategoryViewModel>
@{
    ViewData["Title"] = "Kategoriler";
}

<h2>Kategoriler</h2>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Kategori Adı</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
            </tr>
        }
    </tbody>
</table>
