@model List<RealEstateVehiclePlatform.WebUI.ViewModels.ListingImage.ListingImageViewModel>

@{
    ViewData["Title"] = "İlan Görselleri";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var listingId = (int)ViewBag.ListingId;
}

<section class="image-page-header">
    <div class="container">
        <span class="page-label">İlan Yönetimi</span>

        <div class="d-flex justify-content-between align-items-end flex-wrap gap-3">
            <div>
                <h1>İlan Görselleri</h1>

                <p>
                    @ViewBag.ListingNo — @ViewBag.ListingTitle
                </p>
            </div>

            <a href="/UserListingImage/Upload?listingId=@listingId"
               class="upload-button">
                <i class="bi bi-cloud-arrow-up"></i>
                Yeni Görsel Yükle
            </a>
        </div>
    </div>
</section>

<section class="image-page-content">
    <div class="container">

        @if (Model.Any())
        {
            <div class="row g-4">
                @foreach (var image in Model)
                {
                    <div class="col-md-6 col-xl-4">
                        <article class="image-card">

                            <div class="image-preview">
                                <img src="@image.ImageUrl"
                                     alt="İlan görseli" />

                                @if (image.IsMainImage)
                                {
                                    <span class="main-image-badge">
                                        <i class="bi bi-star-fill"></i>
                                        Ana Görsel
                                    </span>
                                }
                            </div>

                            <div class="image-card-body">
                                <span>
                                    Sıralama: @image.DisplayOrder
                                </span>

                                <div class="image-actions">
                                    @if (!image.IsMainImage)
                                    {
                                        <form asp-action="SetMain"
                                              method="post">
                                            <input type="hidden"
                                                   name="imageId"
                                                   value="@image.Id" />

                                            <input type="hidden"
                                                   name="listingId"
                                                   value="@listingId" />

                                            <button type="submit"
                                                    class="main-button">
                                                <i class="bi bi-star"></i>
                                                Ana Görsel Yap
                                            </button>
                                        </form>
                                    }

                                    <button type="button"
                                            class="delete-image-button"
                                            data-image-id="@image.Id"
                                            data-listing-id="@listingId"
                                            data-image-url="@image.ImageUrl">
                                        <i class="bi bi-trash"></i>
                                        Sil
                                    </button>
                                </div>
                            </div>

                        </article>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-images">
                <i class="bi bi-images"></i>

                <h3>Henüz ilan görseli yok</h3>

                <p>
                    İlanın liste ve detay sayfalarında daha dikkat çekici
                    görünmesi için görsel yükleyebilirsin.
                </p>

                <a href="/UserListingImage/Upload?listingId=@listingId"
                   class="btn btn-primary">
                    İlk Görseli Yükle
                </a>
            </div>
        }

        <a href="/UserListing"
           class="back-link">
            <i class="bi bi-arrow-left"></i>
            İlanlarıma dön
        </a>
    </div>
</section>

<style>
    .image-page-header {
        padding: 65px 0 45px;
        background: linear-gradient(135deg, #eff6ff, #f8fafc);
    }

    .page-label {
        color: #2563eb;
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 1.5px;
        text-transform: uppercase;
    }

    .image-page-header h1 {
        margin: 8px 0;
        color: #0f172a;
        font-size: clamp(34px, 5vw, 52px);
        font-weight: 850;
    }

    .image-page-header p {
        margin: 0;
        color: #64748b;
    }

    .upload-button {
        min-height: 48px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 0 18px;
        border-radius: 13px;
        background: #2563eb;
        color: #fff;
        font-weight: 800;
        text-decoration: none;
    }

    .image-page-content {
        padding: 50px 0 90px;
    }

    .image-card {
        overflow: hidden;
        border: 1px solid #e2e8f0;
        border-radius: 22px;
        background: #fff;
        box-shadow: 0 12px 35px rgba(15, 23, 42, .07);
    }

    .image-preview {
        position: relative;
        height: 260px;
        background: #e2e8f0;
    }

        .image-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .main-image-badge {
        position: absolute;
        top: 14px;
        left: 14px;
        padding: 7px 11px;
        border-radius: 999px;
        background: #fef3c7;
        color: #b45309;
        font-size: 12px;
        font-weight: 800;
    }

    .image-card-body {
        padding: 19px;
    }

        .image-card-body > span {
            color: #64748b;
            font-size: 13px;
        }

    .image-actions {
        display: flex;
        gap: 9px;
        margin-top: 15px;
    }

        .image-actions form {
            flex: 1;
        }

    .main-button,
    .delete-image-button {
        width: 100%;
        min-height: 42px;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 6px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 700;
    }

    .main-button {
        border: 0;
        background: #eff6ff;
        color: #1d4ed8;
    }

    .delete-image-button {
        flex: 1;
        border: 1px solid #fecaca;
        background: #fff;
        color: #dc2626;
    }

    .empty-images {
        padding: 75px 25px;
        border: 1px dashed #cbd5e1;
        border-radius: 24px;
        background: #fff;
        text-align: center;
    }

        .empty-images > i {
            color: #2563eb;
            font-size: 60px;
        }

        .empty-images h3 {
            margin-top: 18px;
            font-weight: 800;
        }

        .empty-images p {
            max-width: 520px;
            margin: 10px auto 24px;
            color: #64748b;
        }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        margin-top: 28px;
        color: #64748b;
        font-weight: 700;
        text-decoration: none;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.querySelectorAll(".delete-image-button")
        .forEach(function (button) {

        button.addEventListener("click", async function () {
        const result = await Swal.fire({
        title: "Görsel silinsin mi?",
        text: "Seçilen ilan görseli silinecek.",
        icon: "warning",
        showCancelButton: true,
        confirmButtonText: "Evet, sil",
        cancelButtonText: "Vazgeç",
        confirmButtonColor: "#dc2626",
        cancelButtonColor: "#64748b"
        });

        if (!result.isConfirmed) {
        return;
        }

        const form = document.createElement("form");

        form.method = "post";
        form.action = "/UserListingImage/Delete";

        const fields = {
        imageId: this.dataset.imageId,
        listingId: this.dataset.listingId,
        imageUrl: this.dataset.imageUrl
        };

        Object.keys(fields).forEach(function (key) {
        const input = document.createElement("input");

        input.type = "hidden";
        input.name = key;
        input.value = fields[key];

        form.appendChild(input);
        });

        document.body.appendChild(form);
        form.submit();
        });
        });
    </script>
}