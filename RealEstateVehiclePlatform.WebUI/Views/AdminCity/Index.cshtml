@model List<RealEstateVehiclePlatform.WebUI.ViewModels.City.CityViewModel>

@{
    ViewData["Title"] = "Şehir Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="fw-bold mb-1">Şehirler</h5>
            <small class="text-muted">İlanlarda kullanılacak şehirleri buradan yönetebilirsin.</small>
        </div>

        <a href="/AdminCity/Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i>
            Yeni Şehir
        </a>
    </div>

    <table class="table align-middle table-hover">
        <thead>
            <tr>
                <th style="width:80px;">ID</th>
                <th>Şehir Adı</th>
                <th style="width:180px;" class="text-end">İşlemler</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <span class="badge bg-primary-subtle text-primary">
                            #@item.Id
                        </span>
                    </td>

                    <td class="fw-semibold">
                        @item.Name
                    </td>

                    <td class="text-end">
                        <a href="/AdminCity/Update/@item.Id"
                           class="btn btn-sm btn-soft-primary me-1">
                            <i class="bi bi-pencil-square"></i>
                        </a>

                        <a href="#"
                           class="btn btn-sm btn-soft-danger delete-btn"
                           data-url="/AdminCity/Delete/@item.Id"
                           data-title="@item.Name şehri silinecek.">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>