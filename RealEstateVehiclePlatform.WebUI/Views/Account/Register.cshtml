@model RealEstateVehiclePlatform.WebUI.ViewModels.Auth.RegisterViewModel

@{
    ViewData["Title"] = "Kayıt Ol";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Kayıt Ol - RealEstateVehiclePlatform</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
          rel="stylesheet" />

    <style>
            body {
                min-height: 100vh;
                margin: 0;
                display: grid;
                place-items: center;
                padding: 40px 15px;
                background: radial-gradient(circle at 10% 15%, rgba(255,255,255,.18), transparent 30%), linear-gradient(135deg, #2563eb, #1e3a8a);
                font-family: "Segoe UI", sans-serif;
            }

            .register-wrapper {
                width: 100%;
                max-width: 1050px;
                display: grid;
                grid-template-columns: 1fr 520px;
                overflow: hidden;
                border-radius: 30px;
                background: #fff;
                box-shadow: 0 30px 90px rgba(15, 23, 42, .3);
            }

            .register-information {
                position: relative;
                overflow: hidden;
                display: flex;
                flex-direction: column;
                justify-content: center;
                padding: 55px;
                background: linear-gradient(145deg, #0f172a, #1e3a8a);
                color: #fff;
            }

                .register-information::after {
                    content: "";
                    position: absolute;
                    width: 280px;
                    height: 280px;
                    right: -100px;
                    bottom: -100px;
                    border-radius: 50%;
                    background: rgba(255,255,255,.08);
                }

            .brand {
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 45px;
                font-size: 23px;
                font-weight: 800;
            }

                .brand i {
                    font-size: 32px;
                    color: #60a5fa;
                }

            .register-information h1 {
                max-width: 450px;
                margin-bottom: 18px;
                font-size: 46px;
                font-weight: 850;
                line-height: 1.12;
            }

            .register-information > p {
                max-width: 450px;
                color: #cbd5e1;
                line-height: 1.7;
            }

            .feature-list {
                display: flex;
                flex-direction: column;
                gap: 17px;
                margin-top: 35px;
            }

            .feature-item {
                display: flex;
                align-items: center;
                gap: 12px;
                color: #e2e8f0;
            }

                .feature-item i {
                    width: 34px;
                    height: 34px;
                    display: grid;
                    place-items: center;
                    border-radius: 10px;
                    background: rgba(96,165,250,.16);
                    color: #93c5fd;
                }

            .register-form-area {
                padding: 48px;
            }

            .form-header {
                margin-bottom: 30px;
            }

                .form-header span {
                    color: #2563eb;
                    font-size: 13px;
                    font-weight: 800;
                    letter-spacing: 1.3px;
                    text-transform: uppercase;
                }

                .form-header h2 {
                    margin: 7px 0;
                    color: #0f172a;
                    font-size: 34px;
                    font-weight: 850;
                }

                .form-header p {
                    margin: 0;
                    color: #64748b;
                }

            .form-label {
                color: #334155;
                font-weight: 700;
            }

            .input-group-text {
                min-width: 48px;
                justify-content: center;
                border-color: #dbe3ef;
                background: #f8fafc;
                color: #2563eb;
            }

            .form-control {
                min-height: 50px;
                border-color: #dbe3ef;
            }

                .form-control:focus {
                    border-color: #2563eb;
                    box-shadow: 0 0 0 .2rem rgba(37, 99, 235, .12);
                }

            .register-button {
                min-height: 53px;
                border: 0;
                border-radius: 13px;
                background: #2563eb;
                color: #fff;
                font-weight: 800;
            }

                .register-button:hover {
                    background: #1d4ed8;
                    color: #fff;
                }

            .login-link {
                margin-top: 23px;
                color: #64748b;
                text-align: center;
            }

                .login-link a {
                    color: #2563eb;
                    font-weight: 800;
                    text-decoration: none;
                }

            .back-home {
                display: block;
                margin-top: 17px;
                color: #94a3b8;
                font-size: 14px;
                text-align: center;
                text-decoration: none;
            }

                .back-home:hover {
                    color: #2563eb;
                }

            .text-danger {
                display: block;
                margin-top: 5px;
                font-size: 13px;
            }

            @@media (max-width: 900px) {
                .register-wrapper {
                    max-width: 560px;
                    grid-template-columns: 1fr;
                }

                .register-information {
                    padding: 38px;
                }

                    .register-information h1 {
                        font-size: 35px;
                    }

                .feature-list {
                    display: none;
                }

                .register-form-area {
                    padding: 38px;
                }
            }
    </style>
</head>

<body>

    <div class="register-wrapper">

        <section class="register-information">
            <a href="/" class="brand text-decoration-none text-white">
                <i class="bi bi-buildings"></i>
                RealEstate
            </a>

            <h1>Yeni fırsatları keşfetmeye başla.</h1>

            <p>
                Ev, arsa ve araç ilanlarını incelemek, favorilerine eklemek,
                randevu oluşturmak ve ilan sahipleriyle iletişime geçmek için
                hesabını oluştur.
            </p>

            <div class="feature-list">
                <div class="feature-item">
                    <i class="bi bi-heart"></i>
                    Favori ilanlarını kaydet
                </div>

                <div class="feature-item">
                    <i class="bi bi-calendar-check"></i>
                    Kolayca randevu oluştur
                </div>

                <div class="feature-item">
                    <i class="bi bi-chat-dots"></i>
                    İlan sahipleriyle mesajlaş
                </div>

                <div class="feature-item">
                    <i class="bi bi-shield-check"></i>
                    Güvenli kullanıcı hesabı
                </div>
            </div>
        </section>

        <section class="register-form-area">
            <div class="form-header">
                <span>Ücretsiz Hesap</span>
                <h2>Kayıt Ol</h2>
                <p>Platformu kullanmaya başlamak için bilgilerini gir.</p>
            </div>

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.ErrorMessage
                </div>
            }

            <form asp-action="Register" method="post">

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label">
                        Ad Soyad
                    </label>

                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-person"></i>
                        </span>

                        <input asp-for="FullName"
                               class="form-control"
                               placeholder="Adınız ve soyadınız" />
                    </div>

                    <span asp-validation-for="FullName"
                          class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="UserName" class="form-label">
                        Kullanıcı Adı
                    </label>

                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-at"></i>
                        </span>

                        <input asp-for="UserName"
                               class="form-control"
                               placeholder="Kullanıcı adınız" />
                    </div>

                    <span asp-validation-for="UserName"
                          class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">
                        Email
                    </label>

                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-envelope"></i>
                        </span>

                        <input asp-for="Email"
                               class="form-control"
                               placeholder="ornek@email.com" />
                    </div>

                    <span asp-validation-for="Email"
                          class="text-danger"></span>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="Password" class="form-label">
                            Şifre
                        </label>

                        <input asp-for="Password"
                               type="password"
                               class="form-control"
                               placeholder="En az 6 karakter" />

                        <span asp-validation-for="Password"
                              class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ConfirmPassword" class="form-label">
                            Şifre Tekrar
                        </label>

                        <input asp-for="ConfirmPassword"
                               type="password"
                               class="form-control"
                               placeholder="Şifrenizi tekrar girin" />

                        <span asp-validation-for="ConfirmPassword"
                              class="text-danger"></span>
                    </div>
                </div>

                <button type="submit"
                        class="btn register-button w-100">
                    <i class="bi bi-person-plus me-1"></i>
                    Hesabımı Oluştur
                </button>

            </form>

            <div class="login-link">
                Zaten hesabın var mı?
                <a href="/Account/Login">Giriş Yap</a>
            </div>

            <a href="/" class="back-home">
                <i class="bi bi-arrow-left me-1"></i>
                Ana sayfaya dön
            </a>
        </section>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <partial name="_ValidationScriptsPartial" />

</body>
</html>