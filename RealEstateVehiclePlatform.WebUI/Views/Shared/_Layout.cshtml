    <!-- CHATBOT FONKSİYON SCRIPT'I -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {
        const toggleBtn = document.getElementById("aiChatbotToggleBtn");
        const chatWindow = document.getElementById("aiChatWindow");
        const closeBtn = document.getElementById("aiChatCloseBtn");
        const chatForm = document.getElementById("aiChatForm");
        const chatInput = document.getElementById("aiChatInput");
        const chatBody = document.getElementById("aiChatBody");
        const suggestBtns = document.querySelectorAll(".chat-suggest-btn");

        // Paneli aç / kapat
        toggleBtn.addEventListener("click", function () {
        chatWindow.classList.toggle("d-none");
        scrollToBottom();
        });

        closeBtn.addEventListener("click", function () {
        chatWindow.classList.add("d-none");
        });

        // Hazır önerilere tıklama
        suggestBtns.forEach(btn => {
        btn.addEventListener("click", function () {
        handleSendMessage(this.innerText);
        });
        });

        // Form Gönderme
        chatForm.addEventListener("submit", function (e) {
        e.preventDefault();
        const text = chatInput.value.trim();
        if (text) {
        handleSendMessage(text);
        chatInput.value = "";
        }
        });

        function scrollToBottom() {
        chatBody.scrollTop = chatBody.scrollHeight;
        }

        async function handleSendMessage(text) {
        // 1. Kullanıcı mesajını ekrana yaz
        appendMessage(text, "user");
        scrollToBottom();

        // 2. Yazıyor animasyonunu ekle
        const typingDiv = document.createElement("div");
        typingDiv.className = "ai-message assistant typing-indicator-msg";
        typingDiv.innerHTML = `
        <div class="message-bubble bg-light text-muted py-2">
        <span class="spinner-grow spinner-grow-sm text-primary me-1" role="status"></span>
        Asistan düşünüyor...
        </div>
        `;
        chatBody.appendChild(typingDiv);
        scrollToBottom();

        try {
        // 3. Controller'a AJAX isteği fırlat
        const response = await fetch("/Chatbot/Ask", {
        method: "POST",
        headers: {
        "Content-Type": "application/x-www-form-urlencoded"
        },
        body: new URLSearchParams({ message: text })
        });

        const result = await response.json();

        // Animasyonu kaldır
        typingDiv.remove();

        // 4. Gelen cevabı ekrana yaz
        appendMessage(result.reply, "assistant");
        scrollToBottom();

        } catch (error) {
        typingDiv.remove();
        appendMessage("Üzgünüm, şu anda yanıt veremiyorum. Lütfen bağlantınızı kontrol edin.", "assistant");
        scrollToBottom();
        }
        }

        function appendMessage(htmlContent, sender) {
        const msgDiv = document.createElement("div");
        msgDiv.className = `ai-message ${sender}`;
        msgDiv.innerHTML = `<div class="message-bubble shadow-sm">${htmlContent}</div>`;
        chatBody.appendChild(msgDiv);
        }
        });
    </script>
</body>
</html>