@model List<RealEstateVehiclePlatform.WebUI.ViewModels.ListingImage.ListingImageViewModel>

@{
    ViewData["Title"] = "İlan Görselleri";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var listingId = (int)ViewBag.ListingId;
}

<section class="image-page-header">
    <div class="container">
        <span class="page-label">İlan Yönetimi</span>
        <div class="d-flex justify-content-between align-items-end flex-wrap gap-3">
            <div>
                <h1>İlan Görselleri</h1>
                <p class="text-secondary mb-0">
                    <i class="bi bi-tag-fill me-1 text-primary"></i> İlan No: <strong>@ViewBag.ListingNo</strong> — @ViewBag.ListingTitle
                </p>
            </div>
            <div class="d-flex gap-2">
                <a href="#uploadSection" class="upload-scroll-btn btn btn-primary">
                    <i class="bi bi-cloud-arrow-up me-1"></i> Yeni Görsel Yükle
                </a>
                <a href="/UserListing" class="back-to-listings-btn">
                    <i class="bi bi-arrow-left"></i> İlanlarıma Dön
                </a>
            </div>
        </div>
    </div>
</section>

<section class="image-page-content">
    <div class="container">

        <!-- SÜRÜKLE BIRAK YÜKLEME ALANI (DRAG AND DROP) -->
        <div id="uploadSection" class="upload-section mb-5">
            <div class="card border-0 shadow-sm upload-card-wrapper">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3 text-dark">
                        <i class="bi bi-cloud-arrow-up-fill me-2 text-primary"></i> Çoklu Görsel Yükleme Paneli
                    </h5>

                    <div id="dropZone" class="drag-drop-zone">
                        <div class="drop-zone-content text-center py-4">
                            <div class="upload-animated-icon mb-3">
                                <i class="bi bi-images text-primary" style="font-size: 3.5rem;"></i>
                            </div>
                            <h4 class="fw-bold text-dark">Görselleri Buraya Sürükleyin ve Bırakın</h4>
                            <p class="text-muted fs-6">veya dosyalarınızı seçmek için bu alana tıklayın</p>
                            <span class="badge bg-light text-secondary border px-3 py-2 fs-7">
                                PNG, JPG, JPEG, WEBP (Otomatik Boyut Sıkıştırma Aktif)
                            </span>
                        </div>
                        <input type="file" id="fileInput" multiple accept=".jpg,.jpeg,.png,.webp" class="d-none" />
                    </div>

                    <!-- YÜKLEME SIRASI (QUEUE) -->
                    <div id="uploadQueueWrapper" class="mt-4 d-none">
                        <h6 class="fw-bold text-dark mb-3 d-flex justify-content-between align-items-center">
                            <span>Sıkıştırılan ve Yüklenen Görseller</span>
                            <span id="queueProgressBadge" class="badge bg-primary px-3 py-2">0 / 0</span>
                        </h6>
                        <div id="uploadQueue" class="d-flex flex-column gap-2 max-height-queue">
                            <!-- Javascript burayı dolduracak -->
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- MEVCUT GÖRSELLERİN LİSTESİ -->
        <div class="uploaded-images-section">
            <h4 class="fw-bold text-dark mb-4 d-flex align-items-center">
                <i class="bi bi-grid-3x3-gap-fill me-2 text-primary"></i> Yayındaki Görseller
                <span class="badge bg-secondary ms-2 fs-7 font-normal">@Model.Count Görsel</span>
            </h4>

            @if (Model.Any())
            {
                <div class="row g-4" id="imagesGrid">
                    @foreach (var image in Model)
                    {
                        <div class="col-md-6 col-lg-4 col-xl-3 image-col-item">
                            <article class="image-card-premium @(image.IsMainImage ? "is-main" : "")">
                                <div class="image-wrapper-ratio">
                                    <img src="@image.ImageUrl" alt="İlan görseli" loading="lazy" />

                                    @if (image.IsMainImage)
                                    {
                                        <div class="main-badge-premium">
                                            <i class="bi bi-star-fill me-1"></i> Ana Görsel
                                        </div>
                                    }
                                </div>
                                <div class="image-footer-actions">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="order-badge">
                                            <i class="bi bi-sort-numeric-down me-1"></i> Sıra: <strong>@image.DisplayOrder</strong>
                                        </span>
                                    </div>

                                    <div class="d-flex gap-2">
                                        @if (!image.IsMainImage)
                                        {
                                            <form asp-action="SetMain" method="post" class="flex-grow-1 m-0">
                                                <input type="hidden" name="imageId" value="@image.Id" />
                                                <input type="hidden" name="listingId" value="@listingId" />
                                                <button type="submit" class="btn btn-sm btn-light-primary w-100 py-2 font-semibold">
                                                    <i class="bi bi-star me-1"></i> Ana Görsel Yap
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-success w-100 py-2 font-semibold disabled flex-grow-1">
                                                <i class="bi bi-star-fill me-1"></i> Ana Görsel
                                            </button>
                                        }

                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger btn-delete-premium"
                                                data-image-id="@image.Id"
                                                data-listing-id="@listingId"
                                                data-image-url="@image.ImageUrl"
                                                title="Görseli Sil">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </div>
                                </div>
                            </article>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-images-state text-center py-5 border border-dashed rounded-4 bg-white">
                    <div class="empty-state-icon mb-3">
                        <i class="bi bi-image text-muted" style="font-size: 4rem;"></i>
                    </div>
                    <h4 class="fw-bold text-dark">Henüz Görsel Yüklenmemiş</h4>
                    <p class="text-muted max-width-empty-text mx-auto fs-6">
                        Bu ilanın arama sonuçlarında ve detay sayfasında görüntülenebilmesi için en az bir görsel yüklemelisiniz. Yukarıdaki alana görsellerinizi sürükleyip bırakarak başlayabilirsiniz.
                    </p>
                </div>
            }
        </div>
    </div>
</section>

<style>
    /* CSS Tasarım Sistemi */
    .image-page-header {
        padding: 50px 0 35px;
        background: linear-gradient(135deg, #f0f7ff, #f8fafc);
        border-bottom: 1px solid #e2e8f0;
    }

    .page-label {
        color: #2563eb;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 1.5px;
        text-transform: uppercase;
    }

    .image-page-header h1 {
        margin: 5px 0;
        color: #0f172a;
        font-size: 2.2rem;
        font-weight: 800;
    }

    .back-to-listings-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 10px 18px;
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        background: #fff;
        color: #475569;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s ease;
    }

        .back-to-listings-btn:hover {
            background: #f8fafc;
            color: #0f172a;
            border-color: #94a3b8;
        }

    .image-page-content {
        padding: 40px 0 80px;
        background-color: #f8fafc;
    }

    /* Drag & Drop Alanı */
    .upload-card-wrapper {
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05) !important;
    }

    .drag-drop-zone {
        border: 2px dashed #cbd5e1;
        border-radius: 14px;
        background-color: #fdfdfd;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
    }

        .drag-drop-zone:hover, .drag-drop-zone.dragover {
            border-color: #2563eb;
            background-color: #f0f7ff;
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
        }

    .upload-animated-icon i {
        display: inline-block;
        transition: transform 0.3s ease;
    }

    .drag-drop-zone:hover .upload-animated-icon i,
    .drag-drop-zone.dragover .upload-animated-icon i {
        transform: translateY(-5px);
    }

    /* Sıra Tasarımı (Queue) */
    .max-height-queue {
        max-height: 350px;
        overflow-y: auto;
        padding-right: 5px;
    }

    .queue-item {
        transition: all 0.2s ease;
        border-color: #e2e8f0 !important;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.02);
    }

    .queue-thumb-wrapper {
        width: 50px;
        height: 50px;
        border-radius: 8px;
        overflow: hidden;
        background-color: #f1f5f9;
        flex-shrink: 0;
    }

    .queue-thumb {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .fs-7 {
        font-size: 0.875rem;
    }

    .fs-8 {
        font-size: 0.75rem;
    }

    .font-semibold {
        font-weight: 600;
    }

    /* Premium Görsel Kartları */
    .image-card-premium {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .image-card-premium:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 25px rgba(0, 0, 0, 0.08);
        }

        .image-card-premium.is-main {
            border-color: #2563eb;
            box-shadow: 0 4px 20px rgba(37, 99, 235, 0.15);
        }

    .image-wrapper-ratio {
        position: relative;
        width: 100%;
        padding-top: 68%; /* 3:2 Aspect Ratio */
        background-color: #f1f5f9;
        overflow: hidden;
    }

        .image-wrapper-ratio img {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

    .image-card-premium:hover .image-wrapper-ratio img {
        transform: scale(1.05);
    }

    .main-badge-premium {
        position: absolute;
        top: 12px;
        left: 12px;
        background: #2563eb;
        color: #fff;
        font-weight: 800;
        font-size: 11px;
        padding: 5px 10px;
        border-radius: 20px;
        box-shadow: 0 4px 8px rgba(37, 99, 235, 0.3);
    }

    .image-footer-actions {
        padding: 15px;
        background: #fff;
        margin-top: auto;
    }

    .order-badge {
        font-size: 12px;
        color: #64748b;
        background: #f1f5f9;
        padding: 4px 10px;
        border-radius: 6px;
    }

    .btn-light-primary {
        background-color: #eff6ff;
        color: #2563eb;
        border: 0;
        transition: all 0.2s ease;
    }

        .btn-light-primary:hover {
            background-color: #2563eb;
            color: #fff;
        }

    .btn-delete-premium {
        transition: all 0.2s ease;
    }

        .btn-delete-premium:hover {
            background-color: #dc2626;
            color: #fff;
            border-color: #dc2626;
        }

    .max-width-empty-text {
        max-width: 480px;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

        const scrollBtn = document.querySelector(".upload-scroll-btn");
        if (scrollBtn) {
        scrollBtn.addEventListener("click", function (e) {
        e.preventDefault();
        document.querySelector(this.getAttribute("href")).scrollIntoView({
        behavior: "smooth"
        });
        });
        }

        const dropZone = document.getElementById("dropZone");
        const fileInput = document.getElementById("fileInput");
        const uploadQueue = document.getElementById("uploadQueue");
        const uploadQueueWrapper = document.getElementById("uploadQueueWrapper");
        const queueProgressBadge = document.getElementById("queueProgressBadge");
        const listingId = @listingId;

        let totalFiles = 0;
        let completedFiles = 0;

        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
        dropZone.addEventListener(eventName, preventDefaults, false);
        document.body.addEventListener(eventName, preventDefaults, false);
        });

        ['dragenter', 'dragover'].forEach(eventName => {
        dropZone.addEventListener(eventName, () => dropZone.classList.add('dragover'), false);
        });

        ['dragleave', 'drop'].forEach(eventName => {
        dropZone.addEventListener(eventName, () => dropZone.classList.remove('dragover'), false);
        });

        dropZone.addEventListener('drop', function(e) {
        const files = e.dataTransfer.files;
        handleFiles(files);
        }, false);

        dropZone.addEventListener('click', () => fileInput.click());
        fileInput.addEventListener('change', function() {
        handleFiles(this.files);
        });

        function preventDefaults(e) {
        e.preventDefault();
        e.stopPropagation();
        }

        // GÖRSEL SIKIŞTIRMA VE BOYUTLANDIRMA MOTORU (Canvas API)
        function compressImage(file, maxWidth, maxHeight, quality) {
        return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.readAsDataURL(file);
        reader.onload = function (event) {
        const img = new Image();
        img.src = event.target.result;
        img.onload = function () {
        let width = img.width;
        let height = img.height;

        // En boy oranını koruyarak yeniden boyutlandır
        if (width > maxWidth || height > maxHeight) {
        if (width > height) {
        height = Math.round((height * maxWidth) / width);
        width = maxWidth;
        } else {
        width = Math.round((width * maxHeight) / height);
        height = maxHeight;
        }
        }

        // Canvas üzerinde çizim ve sıkıştırma
        const canvas = document.createElement('canvas');
        canvas.width = width;
        canvas.height = height;

        const ctx = canvas.getContext('2d');
        ctx.drawImage(img, 0, 0, width, height);

        canvas.toBlob(
        (blob) => {
        if (blob) {
        // Orijinal uzantı ve isimle sıkıştırılmış File nesnesi oluştur
        const compressedFile = new File([blob], file.name, {
        type: 'image/jpeg',
        lastModified: Date.now()
        });
        resolve(compressedFile);
        } else {
        reject(new Error('Sıkıştırma sırasında blob oluşturulamadı.'));
        }
        },
        'image/jpeg',
        quality
        );
        };
        img.onerror = (err) => reject(err);
        };
        reader.onerror = (err) => reject(err);
        });
        }

        function handleFiles(files) {
        if (files.length === 0) return;

        uploadQueueWrapper.classList.remove('d-none');
        const filesArray = Array.from(files);

        const validFiles = [];
        const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];

        filesArray.forEach(file => {
        if (!allowedTypes.includes(file.type)) {
        Swal.fire({
        title: 'Hatalı Dosya Türü',
        text: `"${file.name}" desteklenen bir formatta değil. Yalnızca JPG, JPEG, PNG ve WEBP yükleyebilirsiniz.`,
        icon: 'error',
        confirmButtonColor: '#2563eb'
        });
        return;
        }
        validFiles.push(file);
        });

        if (validFiles.length === 0) return;

        totalFiles += validFiles.length;
        updateQueueProgress();

        // Her dosyayı önce sıkıştırıp ardından yüklüyoruz (Asenkron)
        validFiles.forEach(async (file) => {
        try {
        // 1920px max boyutta ve 0.8 (80%) kalitede istemci tarafında sıkıştır
        const compressedFile = await compressImage(file, 1920, 1920, 0.8);
        uploadSingleFile(compressedFile);
        } catch (error) {
        // Bir hata durumunda (örn. tarayıcı desteklemiyorsa) orijinal dosyayı gönder
        console.warn("Sıkıştırma hatası, orijinal yükleniyor:", error);
        uploadSingleFile(file);
        }
        });
        }

        function updateQueueProgress() {
        queueProgressBadge.innerText = `${completedFiles} / ${totalFiles}`;
        }

        function uploadSingleFile(file) {
        const itemId = 'upload-' + Math.random().toString(36).substr(2, 9);

        const itemHtml = `
        <div id="${itemId}" class="queue-item p-3 border rounded-3 bg-white d-flex align-items-center justify-content-between mb-2">
        <div class="d-flex align-items-center gap-3 flex-grow-1">
        <div class="queue-thumb-wrapper">
        <img id="thumb-${itemId}" src="" alt="Önizleme" class="queue-thumb" />
        </div>
        <div class="flex-grow-1 pe-3" style="min-width: 0;">
        <h6 class="mb-1 text-truncate fw-bold text-dark fs-7">${file.name}</h6>
        <div class="d-flex align-items-center gap-2">
        <span class="text-muted fs-8">${(file.size / 1024).toFixed(1)} KB</span>
        <div class="progress flex-grow-1" style="height: 6px; min-width: 100px;">
        <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary" role="progressbar" style="width: 0%;"></div>
        </div>
        <span class="progress-text text-primary fw-bold fs-8" id="pct-${itemId}">0%</span>
        </div>
        </div>
        </div>
        <div class="status-icon ms-2" id="status-${itemId}">
        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        </div>
        </div>
        `;

        uploadQueue.insertAdjacentHTML('beforeend', itemHtml);

        const reader = new FileReader();
        reader.onload = function (e) {
        document.getElementById(`thumb-${itemId}`).src = e.target.result;
        };
        reader.readAsDataURL(file);

        const formData = new FormData();
        formData.append('listingId', listingId);
        formData.append('file', file);

        const xhr = new XMLHttpRequest();
        xhr.open('POST', '/UserListingImage/UploadAjax', true);

        xhr.upload.addEventListener('progress', function (e) {
        if (e.lengthComputable) {
        const percent = Math.round((e.loaded / e.total) * 100);
        const bar = document.querySelector(`#${itemId} .progress-bar`);
        const txt = document.getElementById(`pct-${itemId}`);

        bar.style.width = percent + '%';
        txt.innerText = percent + '%';
        }
        }, false);

        xhr.onload = function () {
        completedFiles++;
        updateQueueProgress();

        const statusIcon = document.getElementById(`status-${itemId}`);
        const bar = document.querySelector(`#${itemId} .progress-bar`);
        const txt = document.getElementById(`pct-${itemId}`);

        if (xhr.status === 200) {
        const res = JSON.parse(xhr.responseText);
        if (res.success) {
        bar.className = 'progress-bar bg-success';
        bar.style.width = '100%';
        txt.innerText = '100%';
        txt.className = 'text-success fw-bold fs-8';
        statusIcon.innerHTML = '<i class="bi bi-check-circle-fill text-success fs-5"></i>';
        } else {
        bar.className = 'progress-bar bg-danger';
        txt.className = 'text-danger fw-bold fs-8';
        statusIcon.innerHTML = `<i class="bi bi-exclamation-circle-fill text-danger fs-5" title="${res.message}"></i>`;
        }
        } else {
        bar.className = 'progress-bar bg-danger';
        txt.className = 'text-danger fw-bold fs-8';
        statusIcon.innerHTML = `<i class="bi bi-exclamation-circle-fill text-danger fs-5" title="Sunucu Hatası: ${xhr.status}"></i>`;
        }

        checkQueueFinished();
        };

        xhr.onerror = function () {
        completedFiles++;
        updateQueueProgress();

        const statusIcon = document.getElementById(`status-${itemId}`);
        const bar = document.querySelector(`#${itemId} .progress-bar`);
        const txt = document.getElementById(`pct-${itemId}`);

        bar.className = 'progress-bar bg-danger';
        txt.className = 'text-danger fw-bold fs-8';
        statusIcon.innerHTML = '<i class="bi bi-exclamation-circle-fill text-danger fs-5" title="Bağlantı kesildi"></i>';

        checkQueueFinished();
        };

        xhr.send(formData);
        }

        function checkQueueFinished() {
        if (completedFiles === totalFiles) {
        setTimeout(() => {
        Swal.fire({
        title: 'Yükleme Tamamlandı!',
        text: 'Seçtiğiniz tüm görseller optimize edilerek yüklendi. Sayfa güncelleniyor...',
        icon: 'success',
        timer: 2000,
        showConfirmButton: false
        }).then(() => {
        window.location.reload();
        });
        }, 1000);
        }
        }

        document.querySelectorAll(".btn-delete-premium").forEach(function (button) {
        button.addEventListener("click", async function () {
        const result = await Swal.fire({
        title: "Görsel Silinecek",
        text: "Bu görseli ilandan silmek istediğinizden emin misiniz?",
        icon: "warning",
        showCancelButton: true,
        confirmButtonText: "Evet, sil",
        cancelButtonText: "Vazgeç",
        confirmButtonColor: "#dc2626",
        cancelButtonColor: "#64748b"
        });

        if (!result.isConfirmed) return;

        const form = document.createElement("form");
        form.method = "post";
        form.action = "/UserListingImage/Delete";

        const fields = {
        imageId: this.dataset.imageId,
        listingId: this.dataset.listingId,
        imageUrl: this.dataset.imageUrl
        };

        Object.keys(fields).forEach(key => {
        const input = document.createElement("input");
        input.type = "hidden";
        input.name = key;
        input.value = fields[key];
        form.appendChild(input);
        });

        document.body.appendChild(form);
        form.submit();
        });
        });
        });
    </script>
}