        background: linear-gradient(135deg, #1d4ed8, #1e40af);
        }

        .ai-chatbot-toggle-btn .pulse-ring {
        content: '';
        position: absolute;
        width: 100%;
        height: 100%;
        border-radius: 50%;
        background: rgba(37, 99, 235, 0.4);
        animation: chatbot-pulse-anim 2.5s infinite;
        z-index: -1;
        left: 0;
        top: 0;
        }

        @@keyframes chatbot-pulse-anim {
