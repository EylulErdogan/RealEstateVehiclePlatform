@model RealEstateVehiclePlatform.WebUI.ViewModels.Listing.CreateListingWizardViewModel

@{
    ViewData["Title"] = "Yeni İlan Ver";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="create-listing-header">
    <div class="container">
        <span class="page-label">İlan Yönetimi</span>

        <h1>Yeni İlan Ver</h1>

        <p>
            Ev, arsa veya araç bilgilerini doldur.
            İlanın yönetici onayından sonra yayınlanacaktır.
        </p>
    </div>
</section>

<section class="create-listing-content">
    <div class="container">

        <form asp-controller="UserListing"
              asp-action="Create"
              method="post"
              id="createListingForm">

            @Html.AntiForgeryToken()

            <input asp-for="ListingNo" type="hidden" />

            <input asp-for="ListingNo" type="hidden" />

            <div class="form-card mb-4">

                <div class="card-heading">
                    <div class="heading-icon">
                        <i class="bi bi-card-text"></i>
                    </div>

                    <div>
                        <span>1. Adım</span>
                        <h3>Temel İlan Bilgileri</h3>
                        <p>İlan başlığı, fiyat ve açıklama bilgilerini gir.</p>
                    </div>
                </div>

                <div class="row g-4">

                    <div class="col-lg-8">
                        <label asp-for="Title" class="form-label">
                            İlan Başlığı
                        </label>

                        <input asp-for="Title"
                               class="form-control form-control-lg"
                               placeholder="İlan için açıklayıcı bir başlık giriniz" />
                    </div>

                    <div class="col-lg-4">
                        <label asp-for="Price" class="form-label">
                            Fiyat
                        </label>

                        <div class="input-group">
                            <input asp-for="Price"
                                        type="number"
                                        min="1"
                                        step="1"
                                        class="form-control form-control-lg"
                                        placeholder="Örneğin: 1500000" />

                            <span class="input-group-text">₺</span>
                        </div>
                    </div>

                    <div class="col-12">
                        <label asp-for="Description" class="form-label">
                            Açıklama
                        </label>

                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="6"
                                  placeholder="İlan hakkında detaylı açıklama yazınız"></textarea>
                    </div>

                </div>
            </div>

            <div class="form-card mb-4">

                <div class="card-heading">
                    <div class="heading-icon">
                        <i class="bi bi-ui-checks-grid"></i>
                    </div>

                    <div>
                        <span>2. Adım</span>
                        <h3>Kategori ve Konum</h3>
                        <p>İlan kategorisini, tipini ve konumunu seç.</p>
                    </div>
                </div>

                <div class="row g-4">

                    <div class="col-md-6 col-xl-3">
                        <label asp-for="CategoryId" class="form-label">
                            Kategori
                        </label>

                        <select asp-for="CategoryId"
                                asp-items="Model.Categories"
                                id="categorySelect"
                                class="form-select form-select-lg">
                            <option value="">Kategori seçiniz</option>
                        </select>
                    </div>

                    <div class="col-md-6 col-xl-3">
                        <label asp-for="ListingTypeId" class="form-label">
                            İlan Tipi
                        </label>

                        <select asp-for="ListingTypeId"
                                asp-items="Model.ListingTypes"
                                class="form-select form-select-lg">
                            <option value="">İlan tipi seçiniz</option>
                        </select>
                    </div>

                    <div class="col-md-6 col-xl-3">
                        <label asp-for="CityId" class="form-label">
                            Şehir
                        </label>

                        <select asp-for="CityId"
                                asp-items="Model.Cities"
                                class="form-select form-select-lg">
                            <option value="">Şehir seçiniz</option>
                        </select>
                    </div>

                    <div class="col-md-6 col-xl-3">
                        <label asp-for="DistrictId" class="form-label">
                            İlçe
                        </label>

                        <select asp-for="DistrictId"
                                asp-items="Model.Districts"
                                class="form-select form-select-lg">
                            <option value="">İlçe seçiniz</option>
                        </select>
                    </div>

                    <div class="col-12">
                        <label asp-for="Address" class="form-label">
                            Açık Adres
                        </label>

                        <input asp-for="Address"
                               class="form-control form-control-lg"
                               placeholder="Mahalle, cadde, sokak ve diğer adres bilgileri" />
                    </div>

                </div>
            </div>

            <div id="houseFields"
                 class="form-card detail-section d-none mb-4">

                <div class="card-heading">
                    <div class="heading-icon">
                        <i class="bi bi-house-door"></i>
                    </div>

                    <div>
                        <span>3. Adım</span>
                        <h3>Ev Detayları</h3>
                        <p>Evin teknik ve kullanım bilgilerini gir.</p>
                    </div>
                </div>

                <div class="row g-4">

                    <div class="col-md-6 col-xl-3">
                        <label asp-for="RoomCount" class="form-label">
                            Oda Sayısı
                        </label>

                        <input asp-for="RoomCount"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 col-xl-3">
                        <label asp-for="LivingRoomCount" class="form-label">
                            Salon Sayısı
                        </label>

                        <input asp-for="LivingRoomCount"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 col-xl-3">
                        <label asp-for="GrossSquareMeters" class="form-label">
                            Brüt m²
                        </label>

                        <input asp-for="GrossSquareMeters"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 col-xl-3">
                        <label asp-for="NetSquareMeters" class="form-label">
                            Net m²
                        </label>

                        <input asp-for="NetSquareMeters"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 col-xl-3">
                        <label asp-for="BuildingAge" class="form-label">
                            Bina Yaşı
                        </label>

                        <input asp-for="BuildingAge"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 col-xl-3">
                        <label asp-for="FloorNumber" class="form-label">
                            Bulunduğu Kat
                        </label>

                        <input asp-for="FloorNumber"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 col-xl-3">
                        <label asp-for="TotalFloors" class="form-label">
                            Toplam Kat
                        </label>

                        <input asp-for="TotalFloors"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 col-xl-3">
                        <label asp-for="HeatingType" class="form-label">
                            Isıtma Tipi
                        </label>

                        <input asp-for="HeatingType"
                               class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <div class="boolean-option">
                            <input asp-for="HasBalcony"
                                   class="form-check-input" />

                            <label asp-for="HasBalcony"
                                   class="form-check-label">
                                Balkon Var
                            </label>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="boolean-option">
                            <input asp-for="IsFurnished"
                                   class="form-check-input" />

                            <label asp-for="IsFurnished"
                                   class="form-check-label">
                                Eşyalı
                            </label>
                        </div>
                    </div>

                </div>
            </div>

            <div id="landFields"
                 class="form-card detail-section d-none mb-4">

                <div class="card-heading">
                    <div class="heading-icon">
                        <i class="bi bi-map"></i>
                    </div>

                    <div>
                        <span>3. Adım</span>
                        <h3>Arsa Detayları</h3>
                        <p>Arsanın imar ve tapu bilgilerini gir.</p>
                    </div>
                </div>

                <div class="row g-4">

                    <div class="col-md-6 col-xl-4">
                        <label asp-for="SquareMeters" class="form-label">
                            Metrekare
                        </label>

                        <input asp-for="SquareMeters"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 col-xl-4">
                        <label asp-for="ZoningStatus" class="form-label">
                            İmar Durumu
                        </label>

                        <input asp-for="ZoningStatus"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 col-xl-4">
                        <label asp-for="BlockNo" class="form-label">
                            Ada No
                        </label>

                        <input asp-for="BlockNo"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 col-xl-4">
                        <label asp-for="ParcelNo" class="form-label">
                            Parsel No
                        </label>

                        <input asp-for="ParcelNo"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 col-xl-4">
                        <label asp-for="SheetNo" class="form-label">
                            Pafta No
                        </label>

                        <input asp-for="SheetNo"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 col-xl-4">
                        <div class="boolean-option mt-md-4">
                            <input asp-for="IsSuitableForCredit"
                                   class="form-check-input" />

                            <label asp-for="IsSuitableForCredit"
                                   class="form-check-label">
                                Krediye Uygun
                            </label>
                        </div>
                    </div>

                </div>
            </div>

            <div id="vehicleFields"
                 class="form-card detail-section d-none mb-4">

                <div class="card-heading">
                    <div class="heading-icon">
                        <i class="bi bi-car-front"></i>
                    </div>

                    <div>
                        <span>3. Adım</span>
                        <h3>Araç Detayları</h3>
                        <p>Aracın teknik ve kullanım bilgilerini gir.</p>
                    </div>
                </div>

                <div class="row g-4">

                    <div class="col-md-6 col-xl-3">
                        <label asp-for="Brand" class="form-label">
                            Marka
                        </label>

                        <input asp-for="Brand"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 col-xl-3">
                        <label asp-for="Model" class="form-label">
                            Model
                        </label>

                        <input asp-for="Model"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 col-xl-3">
                        <label asp-for="Year" class="form-label">
                            Model Yılı
                        </label>

                        <input asp-for="Year"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 col-xl-3">
                        <label asp-for="Kilometer" class="form-label">
                            Kilometre
                        </label>

                        <input asp-for="Kilometer"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 col-xl-3">
                        <label asp-for="FuelType" class="form-label">
                            Yakıt Tipi
                        </label>

                        <input asp-for="FuelType"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 col-xl-3">
                        <label asp-for="GearType" class="form-label">
                            Vites Tipi
                        </label>

                        <input asp-for="GearType"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 col-xl-3">
                        <label asp-for="BodyType" class="form-label">
                            Kasa Tipi
                        </label>

                        <input asp-for="BodyType"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 col-xl-3">
                        <label asp-for="Color" class="form-label">
                            Renk
                        </label>

                        <input asp-for="Color"
                               class="form-control" />
                    </div>

                </div>
            </div>

            <div class="form-actions">
                <a href="/UserListing"
                   class="cancel-button">
                    <i class="bi bi-arrow-left"></i>
                    Vazgeç
                </a>

                <button type="submit" class="save-button">
                    <i class="bi bi-check-circle"></i>
                    İlanı Kaydet
                </button>

            </form>
    </div>
</section>

<style>
    .create-listing-header {
        padding: 65px 0 45px;
        background: radial-gradient( circle at 15% 20%, rgba(37, 99, 235, .14), transparent 30%), linear-gradient(135deg, #eff6ff, #f8fafc);
    }

    .page-label {
        display: block;
        color: #2563eb;
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 1.5px;
        text-transform: uppercase;
    }

    .create-listing-header h1 {
        margin: 8px 0 10px;
        color: #0f172a;
        font-size: clamp(35px, 5vw, 54px);
        font-weight: 850;
        letter-spacing: -1.5px;
    }

    .create-listing-header p {
        max-width: 720px;
        margin: 0;
        color: #64748b;
        font-size: 17px;
        line-height: 1.7;
    }

    .create-listing-content {
        padding: 50px 0 100px;
        background: #f8fafc;
    }

    .form-card {
        padding: 32px;
        border: 1px solid #e2e8f0;
        border-radius: 24px;
        background: #fff;
        box-shadow: 0 13px 38px rgba(15, 23, 42, .06);
    }

    .card-heading {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 30px;
        padding-bottom: 22px;
        border-bottom: 1px solid #eef2f7;
    }

    .heading-icon {
        width: 58px;
        height: 58px;
        flex: 0 0 auto;
        display: grid;
        place-items: center;
        border-radius: 17px;
        background: #eff6ff;
        color: #2563eb;
        font-size: 26px;
    }

    .card-heading span {
        color: #2563eb;
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
    }

    .card-heading h3 {
        margin: 3px 0;
        color: #0f172a;
        font-size: 22px;
        font-weight: 850;
    }

    .card-heading p {
        margin: 0;
        color: #64748b;
        font-size: 14px;
    }

    .form-label {
        margin-bottom: 8px;
        color: #334155;
        font-weight: 750;
    }

    .form-control,
    .form-select,
    .input-group-text {
        min-height: 50px;
        border-color: #dbe3ef;
        border-radius: 13px;
    }

    textarea.form-control {
        min-height: auto;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 .2rem rgba(37, 99, 235, .12);
    }

    .input-group .form-control {
        border-radius: 13px 0 0 13px;
    }

    .input-group-text {
        border-radius: 0 13px 13px 0;
        background: #f8fafc;
        color: #2563eb;
        font-weight: 800;
    }

    .boolean-option {
        min-height: 52px;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0 16px;
        border: 1px solid #dbe3ef;
        border-radius: 13px;
        background: #f8fafc;
    }

        .boolean-option .form-check-input {
            width: 19px;
            height: 19px;
            margin: 0;
        }

        .boolean-option .form-check-label {
            color: #334155;
            font-weight: 700;
        }

    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        margin-top: 25px;
    }

    .save-button,
    .cancel-button {
        min-height: 52px;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        border-radius: 13px;
        padding: 0 24px;
        font-weight: 800;
        text-decoration: none;
    }

    .save-button {
        border: 0;
        background: #2563eb;
        color: #fff;
    }

        .save-button:hover {
            background: #1d4ed8;
        }

    .cancel-button {
        background: #e2e8f0;
        color: #475569;
    }

        .cancel-button:hover {
            background: #cbd5e1;
            color: #334155;
        }

    @@media (max-width: 767.98px) {
        .form-card {
            padding: 22px;
        }

        .card-heading {
            align-items: flex-start;
        }

        .form-actions {
            flex-direction: column-reverse;
        }

        .save-button,
        .cancel-button {
            width: 100%;
        }
    }
</style>

@section Scripts {
    <script>
        const categorySelect =
            document.getElementById("categorySelect");

        const houseFields =
            document.getElementById("houseFields");

        const landFields =
            document.getElementById("landFields");

        const vehicleFields =
            document.getElementById("vehicleFields");

        function hideAllDetails() {
            houseFields.classList.add("d-none");
            landFields.classList.add("d-none");
            vehicleFields.classList.add("d-none");
        }

        function showDetailFields() {
            hideAllDetails();

            if (!categorySelect.value) {
                return;
            }

            const selectedText =
                categorySelect
                    .options[categorySelect.selectedIndex]
                    .text
                    .trim()
                    .toLocaleLowerCase("tr-TR");

            if (selectedText === "ev") {
                houseFields.classList.remove("d-none");
            }
            else if (selectedText === "arsa") {
                landFields.classList.remove("d-none");
            }
            else if (
                selectedText === "araç" ||
                selectedText === "arac") {
                vehicleFields.classList.remove("d-none");
            }
        }

        categorySelect.addEventListener(
            "change",
            showDetailFields);

        showDetailFields();
    </script>
}