@model RealEstateVehiclePlatform.WebUI.ViewModels.Profile.UserProfileViewModel

@{
    ViewData["Title"] = "Profilim";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="profile-page-header">
    <div class="container">
        <span class="page-label">Kullanıcı Paneli</span>

        <h1>Profilim</h1>

        <p>
            Hesap bilgilerini görüntüleyebilir ve profilini
            buradan güncelleyebilirsin.
        </p>
    </div>
</section>

<section class="profile-page-content">
    <div class="container">

        <div class="profile-wrapper">

            <aside class="profile-summary-card">
                <div class="profile-avatar">
                    @{
                        var initials = string.Join(
                            "",
                            Model.FullName
                                .Split(
                                    ' ',
                                    StringSplitOptions.RemoveEmptyEntries)
                                .Take(2)
                                .Select(x => x[0].ToString().ToUpper()));
                    }

                    @initials
                </div>

                <h3>@Model.FullName</h3>

                <p>@@@Model.UserName</p>

                <span class="role-badge">
                    <i class="bi bi-person-badge"></i>
                    @Model.Role
                </span>

                <div class="profile-summary-list">
                    <div>
                        <i class="bi bi-envelope"></i>

                        <span>
                            <small>Email</small>
                            <strong>@Model.Email</strong>
                        </span>
                    </div>

                    <div>
                        <i class="bi bi-shield-check"></i>

                        <span>
                            <small>Hesap Durumu</small>
                            <strong>Aktif</strong>
                        </span>
                    </div>
                </div>

                <a href="/UserListing"
                   class="profile-navigation-link">
                    <i class="bi bi-heart"></i>
                    Favorilerim
                </a>
                <a href="/UserFavorite"
                   class="profile-navigation-link">
                    <i class="bi bi-heart"></i>
                    Favorilerim
                </a>

                <a href="/UserAppointment"
                   class="profile-navigation-link">
                    <i class="bi bi-calendar-check"></i>
                    Randevularım
                </a>

                <a href="/UserMessage"
                   class="profile-navigation-link">
                    <i class="bi bi-chat-dots"></i>
                    Mesajlarım
                </a>
                <a href="/UserProfile/ChangePassword"
                   class="profile-navigation-link">
                    <i class="bi bi-shield-lock"></i>
                    Şifre Değiştir
                </a>
            </aside>

            <div class="profile-form-card">
                <div class="form-card-header">
                    <div class="form-icon">
                        <i class="bi bi-person-gear"></i>
                    </div>

                    <div>
                        <h2>Profil Bilgileri</h2>

                        <p>
                            Ad soyad ve kullanıcı adı bilgilerini
                            güncelleyebilirsin.
                        </p>
                    </div>
                </div>

                <form asp-action="Update" method="post">

                    <div class="mb-4">
                        <label class="form-label">
                            Ad Soyad
                        </label>

                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-person"></i>
                            </span>

                            <input name="FullName"
                                   value="@Model.FullName"
                                   class="form-control form-control-lg"
                                   required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">
                            Kullanıcı Adı
                        </label>

                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-at"></i>
                            </span>

                            <input name="UserName"
                                   value="@Model.UserName"
                                   class="form-control form-control-lg"
                                   required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">
                            Email
                        </label>

                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-envelope"></i>
                            </span>

                            <input value="@Model.Email"
                                   class="form-control form-control-lg"
                                   readonly />
                        </div>

                        <small class="form-text">
                            Email adresi bu ekrandan değiştirilemez.
                        </small>
                    </div>

                    <button type="submit"
                            class="profile-save-button">
                        <i class="bi bi-check-circle"></i>
                        Değişiklikleri Kaydet
                    </button>
                </form>
            </div>

        </div>

    </div>
</section>

<style>
    .profile-page-header {
        padding: 65px 0 45px;
        background: radial-gradient( circle at 15% 20%, rgba(37, 99, 235, .14), transparent 30%), linear-gradient(135deg, #eff6ff, #f8fafc);
    }

    .page-label {
        display: block;
        margin-bottom: 8px;
        color: #2563eb;
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 1.5px;
        text-transform: uppercase;
    }

    .profile-page-header h1 {
        margin-bottom: 10px;
        color: #0f172a;
        font-size: clamp(34px, 5vw, 52px);
        font-weight: 850;
        letter-spacing: -1.5px;
    }

    .profile-page-header p {
        max-width: 650px;
        margin: 0;
        color: #64748b;
        font-size: 17px;
    }

    .profile-page-content {
        padding: 55px 0 100px;
    }

    .profile-wrapper {
        display: grid;
        grid-template-columns: 340px 1fr;
        gap: 30px;
        align-items: start;
    }

    .profile-summary-card,
    .profile-form-card {
        border: 1px solid #e2e8f0;
        border-radius: 25px;
        background: #fff;
        box-shadow: 0 16px 45px rgba(15, 23, 42, .07);
    }

    .profile-summary-card {
        padding: 30px;
        text-align: center;
    }

    .profile-avatar {
        width: 105px;
        height: 105px;
        margin: 0 auto 18px;
        display: grid;
        place-items: center;
        border-radius: 50%;
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: #fff;
        font-size: 36px;
        font-weight: 850;
        box-shadow: 0 15px 35px rgba(37, 99, 235, .25);
    }

    .profile-summary-card h3 {
        margin-bottom: 5px;
        color: #0f172a;
        font-weight: 850;
    }

    .profile-summary-card > p {
        margin-bottom: 14px;
        color: #64748b;
    }

    .role-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 12px;
        border-radius: 999px;
        background: #eff6ff;
        color: #1d4ed8;
        font-size: 13px;
        font-weight: 800;
    }

    .profile-summary-list {
        margin: 28px 0;
        padding: 20px 0;
        border-top: 1px solid #eef2f7;
        border-bottom: 1px solid #eef2f7;
        text-align: left;
    }

        .profile-summary-list > div {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 17px;
        }

            .profile-summary-list > div:last-child {
                margin-bottom: 0;
            }

        .profile-summary-list i {
            width: 42px;
            height: 42px;
            display: grid;
            place-items: center;
            border-radius: 12px;
            background: #f8fafc;
            color: #2563eb;
            font-size: 18px;
        }

        .profile-summary-list span {
            min-width: 0;
        }

        .profile-summary-list small,
        .profile-summary-list strong {
            display: block;
        }

        .profile-summary-list small {
            color: #94a3b8;
            font-size: 12px;
        }

        .profile-summary-list strong {
            overflow: hidden;
            color: #334155;
            font-size: 14px;
            text-overflow: ellipsis;
        }

    .profile-navigation-link {
        display: flex;
        align-items: center;
        gap: 11px;
        margin-bottom: 8px;
        padding: 12px 14px;
        border-radius: 12px;
        color: #475569;
        font-weight: 700;
        text-decoration: none;
        transition: .2s;
    }

        .profile-navigation-link:hover {
            background: #eff6ff;
            color: #2563eb;
        }

    .profile-form-card {
        padding: 38px;
    }

    .form-card-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 35px;
    }

    .form-icon {
        width: 62px;
        height: 62px;
        flex: 0 0 auto;
        display: grid;
        place-items: center;
        border-radius: 18px;
        background: #eff6ff;
        color: #2563eb;
        font-size: 28px;
    }

    .form-card-header h2 {
        margin-bottom: 5px;
        color: #0f172a;
        font-size: 27px;
        font-weight: 850;
    }

    .form-card-header p {
        margin: 0;
        color: #64748b;
    }

    .form-label {
        color: #334155;
        font-weight: 750;
    }

    .input-group-text {
        min-width: 52px;
        justify-content: center;
        border-color: #dbe3ef;
        background: #f8fafc;
        color: #2563eb;
    }

    .form-control {
        border-color: #dbe3ef;
        border-radius: 0 13px 13px 0;
    }

        .form-control:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 .2rem rgba(37, 99, 235, .12);
        }

        .form-control[readonly] {
            background: #f8fafc;
            color: #64748b;
        }

    .form-text {
        display: block;
        margin-top: 7px;
        color: #94a3b8;
    }

    .profile-save-button {
        min-height: 53px;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        border: 0;
        border-radius: 14px;
        padding: 0 24px;
        background: #2563eb;
        color: #fff;
        font-weight: 800;
    }

        .profile-save-button:hover {
            background: #1d4ed8;
        }

    @@media (max-width: 991.98px) {
        .profile-wrapper {
            grid-template-columns: 1fr;
        }

        .profile-summary-card {
            max-width: 600px;
        }
    }

    @@media (max-width: 575.98px) {
        .profile-form-card {
            padding: 25px;
        }

        .form-card-header {
            align-items: flex-start;
        }
    }
</style>