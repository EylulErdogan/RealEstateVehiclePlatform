@model RealEstateVehiclePlatform.WebUI.ViewModels.City.UpdateCityViewModel

@{
    ViewData["Title"] = "Şehir Güncelle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-card">
    <div class="mb-4">
        <h4 class="fw-bold">Şehir Güncelle</h4>
        <small class="text-muted">Şehir bilgisini düzenleyebilirsiniz.</small>
    </div>

    <form asp-action="Update" method="post">
        <input asp-for="Id" type="hidden" />

        <div class="mb-4">
            <label class="form-label fw-semibold">Şehir Adı</label>
            <input asp-for="Name" class="form-control form-control-lg" />
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-success">
                <i class="bi bi-arrow-repeat"></i>
                Güncelle
            </button>

            <a href="/AdminCity" class="btn btn-light">
                Vazgeç
            </a>
        </div>
    </form>
</div>