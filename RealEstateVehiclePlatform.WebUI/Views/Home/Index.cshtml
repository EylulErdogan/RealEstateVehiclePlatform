<!-- FAVORİ İŞLEMLERİ İÇİN DİNAMİK AJAX SCRIPT'I -->
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const favButtons = document.querySelectorAll(".listing-fav-btn");

        // Sayfa yüklendiğinde favori olanları renklendir
        async function checkFavStates() {
            try {
                const response = await fetch('/UserFavorite/GetMyFavoritesJson');
                if (response.ok) {
                    const favs = await response.json();
                    if (favs && favs.length > 0) {
                        favButtons.forEach(btn => {
                            const listingId = parseInt(btn.dataset.listingId);
                            if (favs.includes(listingId)) {
                                btn.classList.add("is-favorite");
                                btn.querySelector("i").className = "bi bi-heart-fill";
                            }
                        });
                    }
                }
            } catch(e) {
                // Sessizce yut
            }
        }

        checkFavStates();

        favButtons.forEach(btn => {
            btn.addEventListener("click", async function (e) {
                e.preventDefault();
                e.stopPropagation();

                const listingId = this.dataset.listingId;
                this.disabled = true;

                try {
                    const response = await fetch("/UserFavorite/Toggle", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/x-www-form-urlencoded"
                        },
                        body: new URLSearchParams({ listingId: listingId })
                    });

                    const result = await response.json();

                    if (result.redirectUrl) {
                        window.location.href = result.redirectUrl;
                        return;
                    }

                    if (!result.success) {
                        throw new Error(result.message || "İşlem başarısız.");
                    }

                    const icon = this.querySelector("i");
                    if (result.isFavorite) {
                        this.classList.add("is-favorite");
                        icon.className = "bi bi-heart-fill";
                    } else {
                        this.classList.remove("is-favorite");
                        icon.className = "bi bi-heart";
                    }

                    // SweetAlert2 Toast Bildirimi
                    Swal.fire({
                        toast: true,
                        position: 'top-end',
                        icon: 'success',
                        title: result.message,
                        showConfirmButton: false,
                        timer: 2000
                    });
                }
                catch (error) {
                    Swal.fire('Hata', error.message, 'error');
                }
                finally {
                    this.disabled = false;
                }
            });
        });
    });
</script>