@model RealEstateVehiclePlatform.WebUI.ViewModels.Profile.ChangePasswordViewModel

@{
    ViewData["Title"] = "Şifre Değiştir";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="password-page">
    <div class="container">

        <div class="password-wrapper">

            <div class="password-info">
                <span class="page-label">Hesap Güvenliği</span>

                <h1>Şifreni güncelle</h1>

                <p>
                    Hesabının güvenliği için güçlü ve daha önce
                    kullanmadığın bir şifre belirle.
                </p>

                <div class="security-item">
                    <i class="bi bi-shield-check"></i>

                    <div>
                        <strong>Güvenli şifre kullan</strong>
                        <span>Şifren en az 6 karakterden oluşmalıdır.</span>
                    </div>
                </div>

                <div class="security-item">
                    <i class="bi bi-key"></i>

                    <div>
                        <strong>Mevcut şifren gerekli</strong>
                        <span>
                            Değişikliği doğrulamak için mevcut şifreni gir.
                        </span>
                    </div>
                </div>

                <div class="security-item">
                    <i class="bi bi-box-arrow-in-right"></i>

                    <div>
                        <strong>Yeniden giriş</strong>
                        <span>
                            Şifre değiştikten sonra tekrar giriş yapacaksın.
                        </span>
                    </div>
                </div>
            </div>

            <div class="password-card">

                <div class="card-header-area">
                    <div class="password-icon">
                        <i class="bi bi-lock"></i>
                    </div>

                    <div>
                        <h3>Şifre Bilgileri</h3>
                        <p>Mevcut ve yeni şifreni gir.</p>
                    </div>
                </div>

                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger">
                        @ViewBag.ErrorMessage
                    </div>
                }

                <form asp-action="ChangePassword" method="post">

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="CurrentPassword"
                               class="form-label">
                            Mevcut Şifre
                        </label>

                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-lock"></i>
                            </span>

                            <input asp-for="CurrentPassword"
                                   type="password"
                                   class="form-control form-control-lg"
                                   placeholder="Mevcut şifreniz" />
                        </div>

                        <span asp-validation-for="CurrentPassword"
                              class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="NewPassword"
                               class="form-label">
                            Yeni Şifre
                        </label>

                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-key"></i>
                            </span>

                            <input asp-for="NewPassword"
                                   type="password"
                                   class="form-control form-control-lg"
                                   placeholder="En az 6 karakter" />
                        </div>

                        <span asp-validation-for="NewPassword"
                              class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmNewPassword"
                               class="form-label">
                            Yeni Şifre Tekrar
                        </label>

                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-check2-circle"></i>
                            </span>

                            <input asp-for="ConfirmNewPassword"
                                   type="password"
                                   class="form-control form-control-lg"
                                   placeholder="Yeni şifrenizi tekrar girin" />
                        </div>

                        <span asp-validation-for="ConfirmNewPassword"
                              class="text-danger"></span>
                    </div>

                    <button type="submit"
                            class="change-password-button">
                        <i class="bi bi-shield-lock"></i>
                        Şifreyi Değiştir
                    </button>

                    <a href="/UserProfile"
                       class="back-profile-link">
                        <i class="bi bi-arrow-left"></i>
                        Profilime dön
                    </a>

                </form>
            </div>

        </div>
    </div>
</section>

<style>
    .password-page {
        padding: 75px 0 100px;
        background: radial-gradient( circle at 10% 20%, rgba(37, 99, 235, .12), transparent 30%), #f8fafc;
    }

    .password-wrapper {
        display: grid;
        grid-template-columns: 1fr 470px;
        gap: 60px;
        align-items: center;
    }

    .page-label {
        display: block;
        margin-bottom: 10px;
        color: #2563eb;
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 1.5px;
        text-transform: uppercase;
    }

    .password-info h1 {
        margin-bottom: 18px;
        color: #0f172a;
        font-size: clamp(38px, 5vw, 58px);
        font-weight: 850;
        letter-spacing: -1.5px;
    }

    .password-info > p {
        max-width: 600px;
        margin-bottom: 35px;
        color: #64748b;
        font-size: 17px;
        line-height: 1.75;
    }

    .security-item {
        display: flex;
        align-items: center;
        gap: 15px;
        max-width: 600px;
        margin-bottom: 16px;
        padding: 18px;
        border: 1px solid #e2e8f0;
        border-radius: 17px;
        background: #fff;
    }

        .security-item > i {
            width: 48px;
            height: 48px;
            flex: 0 0 auto;
            display: grid;
            place-items: center;
            border-radius: 14px;
            background: #eff6ff;
            color: #2563eb;
            font-size: 22px;
        }

        .security-item strong,
        .security-item span {
            display: block;
        }

        .security-item strong {
            color: #0f172a;
        }

        .security-item span {
            margin-top: 3px;
            color: #64748b;
            font-size: 14px;
        }

    .password-card {
        padding: 36px;
        border: 1px solid #e2e8f0;
        border-radius: 28px;
        background: #fff;
        box-shadow: 0 25px 65px rgba(15, 23, 42, .12);
    }

    .card-header-area {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 30px;
    }

    .password-icon {
        width: 60px;
        height: 60px;
        display: grid;
        place-items: center;
        border-radius: 17px;
        background: #eff6ff;
        color: #2563eb;
        font-size: 27px;
    }

    .card-header-area h3 {
        margin-bottom: 4px;
        color: #0f172a;
        font-weight: 850;
    }

    .card-header-area p {
        margin: 0;
        color: #64748b;
    }

    .form-label {
        color: #334155;
        font-weight: 750;
    }

    .input-group-text {
        min-width: 52px;
        justify-content: center;
        border-color: #dbe3ef;
        background: #f8fafc;
        color: #2563eb;
    }

    .form-control {
        border-color: #dbe3ef;
    }

        .form-control:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 .2rem rgba(37, 99, 235, .12);
        }

    .text-danger {
        display: block;
        margin-top: 6px;
        font-size: 13px;
    }

    .change-password-button {
        width: 100%;
        min-height: 54px;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        border: 0;
        border-radius: 14px;
        background: #2563eb;
        color: #fff;
        font-weight: 800;
    }

        .change-password-button:hover {
            background: #1d4ed8;
        }

    .back-profile-link {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 7px;
        margin-top: 17px;
        color: #64748b;
        font-weight: 700;
        text-decoration: none;
    }

        .back-profile-link:hover {
            color: #2563eb;
        }

    @@media (max-width: 991.98px) {
        .password-wrapper {
            grid-template-columns: 1fr;
        }

        .password-card {
            max-width: 600px;
        }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}